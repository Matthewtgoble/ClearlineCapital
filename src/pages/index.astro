---
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Clearline Capital | Off-market acquisition intelligence</title>
  <meta name="description" content="Clearline Capital originates off-market opportunities across business acquisitions and real estate through proprietary agentic intelligence, principal-led relationships, disciplined underwriting, and aligned capital." />
  <meta property="og:title" content="Clearline Capital" />
  <meta property="og:description" content="Off-market acquisition intelligence for business acquisitions and real estate, advanced through principal-led relationships, disciplined underwriting, and aligned capital." />
  <style>
    :root {
      --black: #050505;
      --ink: #f7f2e8;
      --muted: rgba(247,242,232,.68);
      --soft: rgba(247,242,232,.42);
      --line: rgba(218,174,98,.28);
      --gold: #d6a85e;
      --gold2: #f0d6a0;
      --card: rgba(9,10,9,.72);
      --card2: rgba(20,18,14,.62);
      --sand: #cbb78d;
      --danger: #b6894f;
      --max: 1180px;
      --serif: Georgia, 'Times New Roman', serif;
      --sans: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      background: var(--black);
      color: var(--ink);
      font-family: var(--sans);
      letter-spacing: -.01em;
      overflow-x: hidden;
    }
    body:before {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 20;
      opacity: .14;
      background-image: radial-gradient(rgba(255,255,255,.45) .5px, transparent .5px);
      background-size: 3px 3px;
      mix-blend-mode: overlay;
    }
    a { color: inherit; text-decoration: none; }
    .site-nav {
      position: fixed;
      z-index: 30;
      top: 0;
      left: 0;
      right: 0;
      height: 104px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px clamp(20px, 4vw, 54px);
      background: linear-gradient(to bottom, rgba(0,0,0,.64), rgba(0,0,0,0));
      backdrop-filter: blur(2px);
      border-bottom: 1px solid transparent;
      transition: background .28s ease, border-color .28s ease, backdrop-filter .28s ease;
    }
    .site-nav.is-scrolled {
      background: linear-gradient(to bottom, rgba(5,5,5,.96), rgba(5,5,5,.9));
      backdrop-filter: blur(10px);
      border-bottom-color: rgba(247,242,232,.09);
    }
    .logo {
      display: flex;
      align-items: center;
      gap: 12px;
      min-width: 180px;
    }
    .logo img { width: 132px; height: auto; display: block; }
    .nav-links { display: flex; align-items: center; gap: 16px; font-size: 12px; text-transform: uppercase; letter-spacing: .18em; color: rgba(247,242,232,.7); }
    .nav-links a { transition: color .25s ease; }
    .nav-links a:hover { color: var(--gold2); }
    .nav-cta { border: 1px solid var(--line); border-radius: 999px; padding: 11px 16px; color: var(--gold2) !important; background: rgba(214,168,94,.08); }
    .hero {
      min-height: 100vh;
      position: relative;
      display: grid;
      align-items: end;
      padding: clamp(132px, 15vh, 176px) clamp(22px, 5vw, 72px) clamp(24px, 4vh, 42px);
      overflow: hidden;
    }
    .hero:before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: linear-gradient(90deg, rgba(0,0,0,.84) 0%, rgba(0,0,0,.44) 44%, rgba(0,0,0,.22) 100%), linear-gradient(to top, rgba(0,0,0,.94) 0%, rgba(0,0,0,.18) 42%, rgba(0,0,0,.5) 100%), url('data:image/jpeg;base64,');
      background-size: cover;
      background-position: center;
      transform: scale(1.025);
      animation: breathe 12s ease-in-out infinite alternate;
    }
    @keyframes breathe { from { transform: scale(1.025); } to { transform: scale(1.065); } }
    .hero-inner { position: relative; z-index: 2; max-width: var(--max); width: 100%; margin: 0 auto; display: grid; grid-template-columns: minmax(0, 1.1fr) 390px; gap: 48px; align-items: end; }
    .hero-narrative { align-self: end; padding-top: clamp(56px, 11vh, 128px); }
    .eyebrow { color: var(--gold2); text-transform: uppercase; letter-spacing: .3em; font-size: clamp(14px, 1.05vw, 15px); margin-bottom: 18px; }
    h1, h2, h3 { font-family: var(--serif); font-weight: 400; margin: 0; text-wrap: pretty; }
    h1 { font-size: clamp(56px, 8vw, 112px); line-height: .88; max-width: 780px; letter-spacing: -.06em; }
    h1 span { display: block; }
    .hero-copy { max-width: 630px; margin-top: 28px; color: rgba(247,242,232,.78); font-size: clamp(15px, 1.35vw, 18px); line-height: 1.58; }
    @media (min-width: 981px) {
      .hero { padding-bottom: 24px; }
      .hero-narrative .eyebrow { margin-bottom: 15px; }
      h1 { font-size: clamp(60px, 4.5vw, 84px); line-height: .92; max-width: 700px; }
      .hero-copy { max-width: 680px; margin-top: 22px; line-height: 1.52; }
      .hero-narrative .secondary-link { margin-top: 18px; }
    }
    .access-card {
      border: 1px solid rgba(214,168,94,.34);
      background: linear-gradient(145deg, rgba(7,8,8,.88), rgba(30,23,13,.72));
      box-shadow: 0 30px 80px rgba(0,0,0,.5);
      border-radius: 2px;
      padding: 28px;
      position: relative;
      overflow: hidden;
    }
    .access-card:before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, var(--gold2), transparent); opacity: .8; }
    .access-title { font-size: 13px; text-transform: uppercase; letter-spacing: .24em; color: var(--gold2); margin-bottom: 18px; }
    .input-row { display: grid; grid-template-columns: 1fr auto; border: 1px solid rgba(247,242,232,.18); background: rgba(0,0,0,.35); }
    .input-row input { min-width: 0; padding: 15px 14px; background: transparent; border: 0; color: var(--ink); outline: none; text-transform: uppercase; letter-spacing: .14em; }
    .input-row button { background: rgba(214,168,94,.14); color: var(--gold2); border: 0; border-left: 1px solid rgba(247,242,232,.14); padding: 0 18px; text-transform: uppercase; letter-spacing: .18em; font-size: 11px; }
    .small { color: rgba(247,242,232,.55); font-size: 12px; line-height: 1.55; margin-top: 14px; }
    .secondary-link { display: inline-flex; margin-top: 22px; color: var(--ink); border-bottom: 1px solid var(--gold); padding-bottom: 6px; font-size: 13px; letter-spacing: .12em; text-transform: uppercase; }
    section { padding: 104px clamp(22px, 5vw, 72px); position: relative; scroll-margin-top: 128px; }
    #firm { padding-top: clamp(72px, 8vh, 96px); }
    .wrap { max-width: var(--max); margin: 0 auto; }
    .split { display: grid; grid-template-columns: .85fr 1.15fr; gap: clamp(34px, 7vw, 96px); align-items: start; }
    h2 { font-size: clamp(38px, 5vw, 74px); line-height: .98; letter-spacing: -.045em; }
    .lead { font-size: clamp(16px, 1.55vw, 21px); line-height: 1.58; color: rgba(247,242,232,.76); margin: 0; }
    .body { color: rgba(247,242,232,.64); font-size: 15px; line-height: 1.75; }
    .rule { height: 1px; background: linear-gradient(90deg, var(--gold), transparent); opacity: .45; margin: 32px 0; }
    .cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 48px; }
    .card { border: 1px solid rgba(247,242,232,.12); background: linear-gradient(145deg, rgba(255,255,255,.045), rgba(255,255,255,.015)); padding: 28px; min-height: 220px; position: relative; }
    .card:after { content: ''; position: absolute; inset: 0; border: 1px solid rgba(214,168,94,.08); transform: translate(5px, 5px); pointer-events: none; }
    .card h3 { font-size: 27px; line-height: 1.05; margin-bottom: 22px; }
    .card p { color: rgba(247,242,232,.62); line-height: 1.68; margin: 0; }
    .section-intro { max-width: 900px; margin-top: 24px; }
    .intelligence-thesis { max-width: 850px; margin: 72px 0 0; padding-top: 28px; border-top: 1px solid rgba(214,168,94,.58); font-family: var(--serif); font-size: clamp(28px, 3vw, 46px); line-height: 1.12; letter-spacing: -.035em; color: rgba(247,242,232,.9); }
    @media (min-width: 981px) {
      .intelligence-cards .card { display: flex; flex-direction: column; }
      .intelligence-cards .card h3 { min-height: 57px; }
    }
    .process-line { position: relative; display: grid; grid-template-columns: repeat(5, 1fr); gap: 20px; margin-top: 54px; padding-top: 30px; }
    .process-line:before { content: ''; position: absolute; left: 0; right: 0; top: 10px; height: 1px; background: linear-gradient(90deg, rgba(214,168,94,.78), rgba(214,168,94,.16)); }
    .process-step { position: relative; padding-right: 18px; }
    .process-step:before { content: ''; position: absolute; top: -25px; left: 0; width: 9px; height: 9px; border-radius: 999px; background: var(--gold2); box-shadow: 0 0 0 6px rgba(214,168,94,.08); }
    .process-step span { display: block; color: var(--gold2); letter-spacing: .18em; font-size: 11px; margin-bottom: 18px; }
    .process-step h3 { font-size: 24px; line-height: 1.05; margin-bottom: 14px; }
    .process-step p { color: rgba(247,242,232,.62); line-height: 1.62; margin: 0; font-size: 14px; }
    .dark-band { background: radial-gradient(circle at 18% 12%, rgba(214,168,94,.16), transparent 32%), linear-gradient(180deg, #050505, #0b0907); }
    .agentic { background: #080706; overflow: hidden; }
    .agentic:before { content: ''; position: absolute; inset: -20%; background: radial-gradient(circle at 76% 28%, rgba(214,168,94,.18), transparent 32%), radial-gradient(circle at 20% 80%, rgba(124,91,45,.22), transparent 28%); opacity: .9; }
    .team-grid { position: relative; display: grid; grid-template-columns: minmax(340px, .95fr) repeat(2, minmax(0, 1fr)); gap: 18px; margin-top: 46px; align-items: stretch; }
    .person { min-height: 426px; border: 1px solid rgba(214,168,94,.24); background: linear-gradient(180deg, rgba(247,242,232,.055), rgba(247,242,232,.018)); padding: 18px; display: flex; flex-direction: column; justify-content: space-between; }
    .principal-card { grid-row: span 2; min-height: 690px; border-color: rgba(214,168,94,.44); background: linear-gradient(180deg, rgba(214,168,94,.12), rgba(247,242,232,.025)); padding: 24px; box-shadow: 0 26px 70px rgba(0,0,0,.34); }
    .portrait { height: 250px; border: 1px solid rgba(247,242,232,.1); background: radial-gradient(circle at 50% 18%, rgba(247,242,232,.2), transparent 18%), linear-gradient(135deg, rgba(214,168,94,.2), rgba(0,0,0,.18)), #111; display: grid; place-items: center; margin-bottom: 18px; overflow: hidden; }
    .principal-card .portrait { height: 380px; margin-bottom: 24px; }
    .portrait span { font-family: var(--serif); font-size: 58px; color: rgba(240,214,160,.52); }
    .portrait img { width: 100%; height: 100%; object-fit: cover; object-position: center center; display: block; filter: none; }
    .person:first-child .portrait img { object-position: center center; filter: none; }
    .portrait img.portrait-matthew,
    .portrait img.portrait-joshua,
    .portrait img.portrait-dex,
    .portrait img.portrait-javi,
    .portrait img.portrait-shay { object-position: center center; }
    .role { color: var(--gold2); text-transform: uppercase; letter-spacing: .16em; font-size: 10px; line-height: 1.45; min-height: 34px; }
    .principal-card .role { font-size: 11px; letter-spacing: .18em; }
    .person h3 { font-size: 28px; margin: 8px 0 10px; }
    .principal-card h3 { font-size: 42px; margin: 12px 0 14px; }
    .person p { color: rgba(247,242,232,.62); line-height: 1.54; margin: 0; font-size: 13px; }
    .principal-card p { color: rgba(247,242,232,.72); font-size: 15px; line-height: 1.62; }
    .access-section { background: linear-gradient(180deg, #050505, #090705); }
    .hidden { display: none; }
    .form-shell { margin-top: 36px; display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .field, textarea { border: 1px solid rgba(247,242,232,.13); background: rgba(247,242,232,.035); padding: 15px 14px; color: var(--ink); min-height: 52px; font: inherit; outline: none; }
    textarea { grid-column: 1 / -1; min-height: 122px; resize: vertical; }
    .submit { grid-column: 1 / -1; justify-self: start; border: 1px solid rgba(214,168,94,.42); background: rgba(214,168,94,.12); color: var(--gold2); padding: 14px 22px; text-transform: uppercase; letter-spacing: .18em; font-size: 12px; }
    footer { padding: 48px clamp(22px, 5vw, 72px); border-top: 1px solid rgba(247,242,232,.1); color: rgba(247,242,232,.46); }
    footer .wrap { display: flex; justify-content: space-between; gap: 20px; font-size: 12px; letter-spacing: .08em; text-transform: uppercase; }
    .mobile-note { display: none; }
    @media (max-width: 980px) {
      .hero-inner, .split { grid-template-columns: 1fr; }
      .hero-narrative { padding-top: 0; }
      .access-card { max-width: 480px; }
      .cards { grid-template-columns: 1fr; }
      .process-line { grid-template-columns: 1fr; gap: 0; margin-top: 42px; padding: 0 0 0 24px; }
      .process-line:before { left: 4px; right: auto; top: 2px; bottom: 6px; width: 1px; height: auto; background: linear-gradient(180deg, rgba(214,168,94,.78), rgba(214,168,94,.16)); }
      .process-step { padding: 0 0 28px; }
      .process-step:before { top: 3px; left: -24px; width: 8px; height: 8px; }
      .process-step span { margin-bottom: 8px; }
      .process-step h3 { font-size: 22px; margin-bottom: 8px; }
      .process-step p { font-size: 13px; line-height: 1.55; max-width: 620px; }
      .team-grid { grid-template-columns: repeat(2, 1fr); }
      .principal-card { grid-column: 1 / -1; grid-row: auto; min-height: auto; }
      .principal-card .portrait { height: clamp(440px, 72vw, 560px); }
      .nav-links { display: none; }
      .mobile-note { display: inline; }
    }
    @media (max-width: 620px) {
      .site-nav {
        position: sticky;
        height: 72px;
        padding: 8px 18px 7px;
        overflow: visible;
        background: linear-gradient(to bottom, rgba(0,0,0,.96), rgba(0,0,0,.86));
        border-bottom: 1px solid rgba(247,242,232,.08);
        backdrop-filter: blur(8px);
      }
      .logo { min-width: 150px; }
      .logo img { width: 98px; }
      .hero { min-height: calc(100svh - 72px); padding: 42px 20px 32px; }
      .hero-narrative { padding-top: 0; }
      section { padding: 72px 20px; scroll-margin-top: 96px; }
      .team-grid, .form-shell { grid-template-columns: 1fr; }
      .principal-card { grid-column: auto; min-height: auto; padding: 20px; }
      .principal-card .portrait { height: clamp(320px, 86vw, 380px); }
      .principal-card h3 { font-size: 38px; }
      .person { min-height: auto; }
      .person:not(.principal-card) { padding: 14px; }
      .person:not(.principal-card) > div { display: grid; grid-template-columns: 96px minmax(0, 1fr); gap: 0 14px; align-items: start; }
      .person:not(.principal-card) .portrait { grid-row: 1 / 4; width: 96px; height: 96px; margin: 0; }
      .person:not(.principal-card) h3 { grid-column: 2; font-size: 24px; margin: 4px 0 6px; }
      .person:not(.principal-card) .role { grid-column: 2; min-height: auto; font-size: 9px; line-height: 1.35; }
      .person:not(.principal-card) p { grid-column: 2; font-size: 12px; line-height: 1.45; }
      .portrait img { object-position: center center; }
      textarea, .submit { grid-column: auto; }
      h1 { font-size: 60px; }
      footer .wrap { flex-direction: column; }
    }
    @media (prefers-reduced-motion: reduce) {
      * { animation: none !important; scroll-behavior: auto !important; }
    }
  </style>
</head>
<body>
  <nav class="site-nav" aria-label="Primary navigation">
    <a class="logo" href="#top" aria-label="Clearline Capital home"><img src="data:image/png;base64," alt="Clearline Capital" /></a>
    <div class="nav-links">
      <a href="#firm">Firm</a>
      <a href="#intelligence">Intelligence</a>
      <a href="#advantage">Human Advantage</a>
      <a href="#circle">Agentic Circle</a>
      <a href="#work">Focus</a>
      <a href="#process">Process</a>
      <a href="#access" class="nav-cta">Request consideration</a>
    </div>
  </nav>

  <main id="top">
    <header class="hero">
      <div class="hero-inner">
        <div class="hero-narrative">
          <div class="eyebrow">Off-market acquisition intelligence</div>
          <h1><span>Off-market acquisitions.</span><span>Agentic intelligence.</span></h1>
          <p class="hero-copy">Clearline Capital originates off-market opportunities across business acquisitions and real estate through a proprietary agentic intelligence system, then advances qualified situations through principal-led relationships, disciplined underwriting, and aligned capital.</p>
          <a class="secondary-link" href="#firm">Enter the overview</a>
        </div>
        <aside class="access-card" aria-label="Invitation access validation">
          <div class="access-title">Invitation access</div>
          <div class="input-row">
            <input id="invite-code" aria-label="Invitation code" placeholder="Invitation code" autocomplete="off" />
            <button id="invite-submit" type="button">Submit</button>
          </div>
          <p class="small">The firm issues invitation codes through trusted relationships. Access begins with referral and fit.</p>
          <a class="secondary-link" href="#access">Request consideration</a>
        </aside>
      </div>
    </header>

    <section id="firm">
      <div class="wrap split">
        <div>
          <div class="eyebrow">The firm</div>
          <h2>The most compelling opportunities rarely begin with a listing.</h2>
        </div>
        <div>
          <p class="lead">Clearline Capital pursues select business and real estate acquisitions where early context, disciplined underwriting, and aligned capital can create a stronger path than a broad auction.</p>
          <div class="rule"></div>
          <p class="body">The firm focuses on succession, growth, transition, or asset complexity where a direct conversation can protect discretion and improve alignment.</p>
          <p class="body">Clearline Capital builds conviction before a listing defines the field, then advances only where context, structure, and execution support the thesis.</p>
        </div>
      </div>
    </section>

    <section id="intelligence" class="dark-band">
      <div class="wrap">
        <div class="eyebrow">The Clearline Intelligence System</div>
        <h2>Acquisition intelligence built to reveal what conventional sourcing overlooks.</h2>
        <p class="lead section-intro">The Clearline Intelligence System is a proprietary acquisition operating layer built for origination, diligence, risk review, and decision support. Refined over months, it coordinates specialized agents through shared context, persistent institutional memory, and structured routing.</p>
        <div class="rule"></div>
        <p class="body">It maps markets, screens targets, researches ownership, develops scenarios, and surfaces openings, contradictions, risks, and next moves a conventional workflow may miss.</p>
        <div class="cards intelligence-cards">
          <article class="card">
            <h3>Continuous Market Coverage</h3>
            <p>Specialized agents map fragmented categories, ownership structures, operating characteristics, and transaction triggers into a continuous view.</p>
          </article>
          <article class="card">
            <h3>Earlier Qualified Openings</h3>
            <p>The system evaluates fit, ownership context, timing, and credible paths to a respectful conversation before a marketed sale begins.</p>
          </article>
          <article class="card">
            <h3>Compounding Institutional Memory</h3>
            <p>Research, diligence, risk, and scenario work remain connected, so each decision starts with accumulated context rather than a blank file.</p>
          </article>
        </div>
        <p class="intelligence-thesis">The result is a compounding acquisition advantage: broader visibility, earlier qualified engagement, faster synthesis, and institutional context that strengthens with every decision.</p>
      </div>
    </section>

    <section id="advantage">
      <div class="wrap split">
        <div>
          <div class="eyebrow">Principal judgment</div>
          <h2>Agentic intelligence expands the field. Principal judgment determines the move.</h2>
        </div>
        <div>
          <p class="lead">The system expands visibility, organizes context, and identifies openings. Matthew determines whom to engage, how to frame the conversation, and whether capital and operating support can align.</p>
          <div class="rule"></div>
          <p class="body">Human approval governs relationships, underwriting, capital decisions, and transaction execution.</p>
        </div>
      </div>
    </section>

    <section id="circle" class="agentic">
      <div class="wrap" style="position:relative; z-index:2;">
        <div class="eyebrow">HUMAN-LED. INTELLIGENCE-MULTIPLIED.</div>
        <h2>The Agentic Circle</h2>
        <p class="lead" style="max-width:820px; margin-top:24px;">The Agentic Circle is Clearline Capital’s operating architecture for agentic acquisition work. Each specialist carries a defined mandate across origination, diligence, risk, infrastructure, strategy, and value creation. Shared context, persistent memory, and structured routing allow the system to surface risks, contradictions, and opportunities before they shape a relationship or investment decision. Matthew retains final authority.</p>
        <div class="team-grid">
          <article class="person principal-card">
            <div>
              <div class="portrait"><img class="portrait-matthew" src="/assets/people/matthew-headshot.jpg" alt="Portrait of Matthew, founder and principal of Clearline Capital" /></div>
              <div class="role">Founder / Principal</div>
              <h3>Matthew</h3>
              <p>Matthew sets investment direction and leads relationships, origination, capital strategy, and execution. He focuses on situations where access, structure, timing, and trust can create a compelling basis for action.</p>
            </div>
          </article>
          <article class="person">
            <div>
              <div class="portrait"><img class="portrait-joshua" src="/assets/people/joshua-headshot.jpg" alt="Portrait of Joshua, operating strategy and orchestration for the firm" /></div>
              <div class="role">Operating Strategy and Orchestration</div>
              <h3>Joshua</h3>
              <p>Coordinates priorities, sequences work, challenges assumptions, and maintains decision quality.</p>
            </div>
          </article>
          <article class="person">
            <div>
              <div class="portrait"><img class="portrait-dex" src="/assets/people/dex-headshot.jpg" alt="Portrait of Dex, origination systems and deal infrastructure for the firm" /></div>
              <div class="role">Origination Systems and Deal Infrastructure</div>
              <h3>Dex</h3>
              <p>Maintains market mapping, target screening, research, data, automation, and infrastructure.</p>
            </div>
          </article>
          <article class="person">
            <div>
              <div class="portrait"><img class="portrait-javi" src="/assets/people/javi-headshot.jpg" alt="Portrait of Javi, diligence and risk intelligence for the firm" /></div>
              <div class="role">Diligence and Risk Intelligence</div>
              <h3>Javi</h3>
              <p>Organizes diligence, identifies material issues, strengthens risk visibility, and prepares matters for legal review.</p>
            </div>
          </article>
          <article class="person">
            <div>
              <div class="portrait"><img class="portrait-shay" src="/assets/people/shay-headshot.jpg" alt="Portrait of Shay, market intelligence and value creation for the firm" /></div>
              <div class="role">Market Intelligence and Value Creation</div>
              <h3>Shay</h3>
              <p>Supports positioning, opportunity presentation, competitive review, brand strategy, and value creation planning.</p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section id="work">
      <div class="wrap">
        <div class="eyebrow">Focus areas</div>
        <h2>Where discretion and timing can change the outcome.</h2>
        <div class="cards">
          <article class="card">
            <h3>Business Acquisitions</h3>
            <p>Founder-led and privately held businesses at moments of succession, expansion, or transition where a direct conversation can create a more aligned path than a broadly marketed sale.</p>
            <p>Current areas of interest include aesthetics, wellness, healthcare services, and other relationship-driven service businesses.</p>
          </article>
          <article class="card">
            <h3>Real Estate</h3>
            <p>Select off-market properties and private situations where local knowledge, underwriting, and creative structure can improve basis, alignment, and control.</p>
          </article>
          <article class="card">
            <h3>Capital and Operating Partnerships</h3>
            <p>Situations where capable operators, aligned equity, and patient capital can be assembled around a clear acquisition thesis.</p>
          </article>
        </div>
      </div>
    </section>

    <section id="process" class="dark-band">
      <div class="wrap">
        <div class="eyebrow">How opportunities move through the firm</div>
        <h2>From intelligence to qualified engagement.</h2>
        <div class="process-line" aria-label="Clearline Capital opportunity process">
          <article class="process-step">
            <span>01</span>
            <h3>Map</h3>
            <p>Clearline Capital maps fragmented categories, ownership structures, business characteristics, and timing events tied to succession, growth, strategic fit, or asset value.</p>
          </article>
          <article class="process-step">
            <span>02</span>
            <h3>Prioritize</h3>
            <p>Potential situations are evaluated against acquisition criteria, ownership context, capital needs, and likelihood of a productive principal conversation.</p>
          </article>
          <article class="process-step">
            <span>03</span>
            <h3>Engage</h3>
            <p>Matthew and the firm’s network open direct, respectful conversations with owners, operators, and principals before a broad auction.</p>
          </article>
          <article class="process-step">
            <span>04</span>
            <h3>Evaluate</h3>
            <p>The operating layer organizes diligence, risk review, market analysis, and scenarios while human judgment determines conviction.</p>
          </article>
          <article class="process-step">
            <span>05</span>
            <h3>Align</h3>
            <p>The firm advances only when owner context, capital structure, operating support, and transaction path fit the thesis.</p>
          </article>
        </div>
      </div>
    </section>

    <section id="access" class="access-section">
      <div class="wrap split">
        <div>
          <div class="eyebrow">Access protocol</div>
          <h2>The right introduction matters.</h2>
        </div>
        <div>
          <p class="lead">Clearline Capital considers opportunities and introductions through referrals, principal relationships, and direct context. Share who you are, who introduced you, and why the conversation matters.</p>
          <form name="access-request" method="POST" action="/thank-you" data-netlify="true" netlify-honeypot="bot-field" class="form-shell">
            <input type="hidden" name="form-name" value="access-request" />
            <p class="hidden"><label>Do not fill this out: <input name="bot-field" /></label></p>
            <input class="field" name="name" placeholder="Name" aria-label="Name" required />
            <input class="field" name="email" type="email" placeholder="Email" aria-label="Email" required />
            <input class="field" name="company" placeholder="Company" aria-label="Company" />
            <input class="field" name="referred-by" placeholder="Referred by" aria-label="Referred by" required />
            <textarea name="context" placeholder="Brief context" aria-label="Brief context" required></textarea>
            <button class="submit" type="submit">Submit for review</button>
          </form>
          <p class="small">Nothing on this page is an offer to sell securities or a solicitation to buy securities.</p>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="wrap">
      <span>Clearline Capital. Principal-led acquisition work.</span>
      <span>Selective capital. Direct context.</span>
    </div>
  </footer>

  <script>
    const nav = document.querySelector('.site-nav');
    function setNavState() {
      nav?.classList.toggle('is-scrolled', window.scrollY > 24);
    }
    setNavState();
    window.addEventListener('scroll', setNavState, { passive: true });

    const inviteInput = document.getElementById('invite-code');
    const inviteButton = document.getElementById('invite-submit');

    async function validateInvite() {
      const code = inviteInput?.value.trim();
      if (!code || !inviteButton) return;

      const originalText = inviteButton.textContent;
      inviteButton.textContent = 'Checking';
      inviteButton.disabled = true;

      try {
        const response = await fetch('/api/validate-code', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ code }),
        });
        const { valid, token } = await response.json();

        if (valid && token) {
          window.location.href = `/contact?token=${encodeURIComponent(token)}`;
          return;
        }

        inviteInput.value = '';
        inviteInput.placeholder = 'Code not recognized';
      } catch (error) {
        inviteInput.placeholder = 'Unable to validate';
      } finally {
        inviteButton.textContent = originalText;
        inviteButton.disabled = false;
      }
    }

    inviteButton?.addEventListener('click', validateInvite);
    inviteInput?.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') validateInvite();
    });
  </script>
</body>
</html>
