<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Clearline Capital</title>
    <meta name="description" content="Clearline Capital — Invite-only private investment enterprise." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>

    <!-- Fade overlay (success) -->
    <div class="fade-overlay" id="fade-overlay"></div>

    <!-- Error overlay -->
    <div class="error-overlay" id="error-overlay">
      <div class="error-content">
        <p class="eyebrow">Access Denied</p>
        <h2 id="error-heading">the code you entered isn't valid, try again</h2>
        <p class="error-sub" id="error-sub"></p>
        <button class="try-again-btn" id="try-again-btn">Try Again</button>
      </div>
    </div>

    <!-- ── Header ── -->
    <header>
      <div class="header-inner">
        <a href="/" class="logo" aria-label="Clearline Capital home">
          <img src="/logo-white.png" alt="Clearline Capital" class="logo-img" />
        </a>
      </div>
    </header>

    <!-- ── Hero ── -->
    <section class="hero" aria-label="Hero">
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <h1>A closed-circuit firm,</h1>
        <p class="hero-sub">where membership is a matter of introduction, not application</p>
        <div class="invite-wrap">
          <div class="invite-divider"></div>
          <div class="invite-row">
            <input type="text" class="invite-input" placeholder="validate invitation" autocomplete="off" />
            <button class="invite-arrow" aria-label="Submit" disabled>
              <svg width="10" height="14" viewBox="0 0 10 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1 1L9 7L1 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
              </svg>
            </button>
          </div>
          <p class="invite-error" aria-live="polite">
            <span class="invite-error-icon">✕</span> the code you entered isn't valid, try again
          </p>
          <label class="invite-confirm" id="invite-confirm-label">
            <input type="checkbox" id="invite-checkbox" />
            <span>I understand my invite code is single-use. Leaving or refreshing this page will permanently invalidate it.</span>
          </label>
        </div>
      </div>
    </section>

  </body>

  <script>
    const inviteWrap     = document.querySelector('.invite-wrap');
    const inviteInput    = document.querySelector('.invite-input');
    const inviteArrow    = document.querySelector('.invite-arrow');
    const inviteCheckbox = document.getElementById('invite-checkbox');
    const inviteConfirm  = document.getElementById('invite-confirm-label');
    const fadeOverlay    = document.getElementById('fade-overlay');
    const errorOverlay   = document.getElementById('error-overlay');
    const errorHeading   = document.getElementById('error-heading');
    const errorSub       = document.getElementById('error-sub');
    const tryAgainBtn    = document.getElementById('try-again-btn');

    const MAX_ATTEMPTS = 2;
    let attempts = 0;

    // Disable arrow until checkbox is checked
    inviteArrow.disabled = true;

    // Show checkbox when typing
    inviteInput.addEventListener('input', () => {
      if (inviteInput.value.trim().length > 0) {
        inviteConfirm.classList.add('visible');
      } else {
        inviteConfirm.classList.remove('visible');
        inviteCheckbox.checked = false;
        inviteArrow.disabled = true;
      }
    });

    // Enable arrow when checkbox is checked
    inviteCheckbox.addEventListener('change', () => {
      inviteArrow.disabled = !inviteCheckbox.checked;
    });

    function showErrorOverlay(locked = false) {
      if (locked) {
        errorHeading.textContent = 'Too many failed attempts.';
        errorSub.textContent = 'Please request a new code from our friend who invited you to join us.';
        errorOverlay.classList.add('visible', 'locked');
      } else {
        errorHeading.textContent = 'Credential unrecognized. Access is reserved for verified invitees.';
        errorSub.textContent = 'Please confirm your referral key with your sponsoring partner.';
        tryAgainBtn.style.display = 'inline-block';
        errorOverlay.classList.add('visible');
      }
    }

    async function submitCode() {
      const code = inviteInput.value.trim();
      if (!code) return;

      const res = await fetch('/api/validate-code', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code }),
      });
      const { valid, token } = await res.json();

      if (valid && token) {
        fadeOverlay.classList.add('visible');
        setTimeout(() => {
          window.location.href = `/contact?token=${token}`;
        }, 250);
      } else {
        attempts++;
        inviteInput.value = '';
        inviteCheckbox.checked = false;
        inviteArrow.disabled = true;
        inviteConfirm.classList.remove('visible');

        if (attempts >= MAX_ATTEMPTS) {
          tryAgainBtn.style.display = 'none';
          showErrorOverlay(true);
        } else {
          showErrorOverlay(false);
        }
      }
    }

    tryAgainBtn.addEventListener('click', () => {
      errorOverlay.classList.remove('visible');
      inviteInput.focus();
    });

    inviteArrow.addEventListener('click', submitCode);
    inviteInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !inviteArrow.disabled) submitCode();
    });
  </script>
</html>

<style>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --gold:      #c9a96e;
    --gold-dim:  rgba(201, 169, 110, 0.45);
    --dark:      #0c0c0c;
    --serif:     'Cormorant Garamond', Georgia, serif;
    --sans:      'Inter', system-ui, sans-serif;
  }

  html, body {
    height: 100%;
    background: #111;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Fade overlay (success) ── */
  .fade-overlay {
    position: fixed;
    inset: 0;
    background: #000;
    opacity: 0;
    pointer-events: none;
    z-index: 999;
    transition: opacity 0.25s ease;
  }

  .fade-overlay.visible {
    opacity: 1;
    pointer-events: all;
  }

  /* ── Error overlay ── */
  .error-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.85);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    opacity: 0;
    pointer-events: none;
    z-index: 500;
    transition: opacity 0.4s ease;
    padding-inline: 2rem;
  }

  .error-overlay.visible {
    opacity: 1;
    pointer-events: all;
  }

  .error-content {
    max-width: 480px;
  }

  .error-content .eyebrow {
    color: #e05555;
    margin-bottom: 1.5rem;
  }

  .error-overlay #error-heading {
    font-family: var(--serif);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 300;
    color: #d4d0cb;
    line-height: 1.25;
    margin-bottom: 1.25rem;
  }

  #error-sub {
    font-family: var(--sans);
    font-size: 0.875rem;
    font-weight: 300;
    color: #9e9a95;
    line-height: 1.9;
    margin-bottom: 2rem;
  }

  .try-again-btn {
    display: inline-block;
    font-family: var(--sans);
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    background: transparent;
    border: 1px solid var(--gold);
    padding: 0.65rem 2rem;
    cursor: pointer;
    transition: background 0.22s ease, color 0.22s ease, border-color 0.22s ease;
  }

  .try-again-btn:hover,
  .try-again-btn:active {
    background: var(--dark);
    border-color: var(--dark);
    color: var(--gold);
  }

  /* ── Header ── */
  header {
    position: fixed;
    inset-block-start: 0;
    inset-inline: 0;
    z-index: 200;
    background: transparent;
  }

  .header-inner {
    padding-inline: 24px;
    padding-top: 1.5rem;
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
  }

  .logo {
    display: flex;
    text-decoration: none;
    line-height: 1;
    position: relative;
  }

  /* Original white logo is hidden but holds the layout dimensions */
  .logo-img {
    height: 74px;
    width: auto;
    display: block;
    visibility: hidden;
  }

  /* Gold satin gradient masked to the exact logo PNG shape */
  .logo::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      110deg,
      #9a6e2a 0%,
      #c9952e 15%,
      #e8c96a 35%,
      #f7e8a0 50%,
      #e8c96a 65%,
      #c9952e 85%,
      #9a6e2a 100%
    );
    background-size: 200% 100%;
    animation: satin 4s ease-in-out infinite alternate;
    -webkit-mask-image: url('/logo-white.png');
    -webkit-mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-image: url('/logo-white.png');
    mask-size: contain;
    mask-repeat: no-repeat;
    mask-position: center;
    pointer-events: none;
  }

  @keyframes satin {
    from { background-position: 0% 50%; }
    to   { background-position: 100% 50%; }
  }

  /* ── Hero ── */
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    background-image: url('/hero-2.png');
    background-size: cover;
    background-position: center top;
    background-color: #111;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(30, 28, 26, 0.35);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-inline: 1.5rem;
    max-width: 820px;
  }

  .eyebrow {
    font-family: var(--sans);
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.5rem;
  }

  .hero-content h1 {
    font-family: var(--serif);
    font-size: clamp(2.6rem, 6vw, 4.8rem);
    font-weight: 300;
    line-height: 1.18;
    color: #fff;
    margin-bottom: 0.75rem;
  }

  .hero-sub {
    font-family: var(--sans);
    font-size: clamp(0.8rem, 1.5vw, 1rem);
    font-weight: 300;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.65);
    margin-bottom: 2.5rem;
  }

  /* ── Invite input ── */
  .invite-wrap {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    margin-inline: auto;
  }

  .invite-divider {
    width: 100%;
    height: 1px;
    background: rgba(255, 255, 255, 0.25);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .invite-row {
    display: flex;
    align-items: center;
    position: relative;
    width: 100%;
  }

  .invite-input {
    width: 320px;
    max-width: 80vw;
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid var(--gold);
    outline: none;
    font-family: var(--sans);
    font-size: 0.72rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    padding: 0.85rem 2.5rem 0.85rem 1.25rem;
    text-align: center;
    transition: background 0.25s ease;
  }

  .invite-row::before {
    content: '';
    position: absolute;
    inset: 0;
    padding: 1px;
    background: linear-gradient(
      90deg,
      #9a6e2a 0%,
      #c9952e 20%,
      #f7e8a0 42%,
      #e8c96a 50%,
      #f7e8a0 58%,
      #c9952e 80%,
      #9a6e2a 100%
    );
    background-size: 200% 100%;
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .invite-row:hover::before {
    opacity: 1;
    animation: border-shimmer 2.5s ease-in-out infinite alternate;
  }

  .invite-row:hover .invite-input {
    border-color: transparent;
  }

  @keyframes border-shimmer {
    from { background-position: 0% 0; }
    to   { background-position: 100% 0; }
  }

  .invite-input::placeholder {
    color: var(--gold);
    opacity: 1;
  }

  .invite-input:focus {
    background: rgba(0, 0, 0, 0.65);
  }

  .invite-arrow {
    position: absolute;
    right: 0.75rem;
    background: none;
    border: none;
    color: var(--gold);
    font-size: 1.1rem;
    cursor: pointer;
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.25s ease, transform 0.25s ease;
    padding: 0;
    line-height: 1;
  }

  .invite-wrap:focus-within .invite-arrow,
  .invite-input:not(:placeholder-shown) ~ .invite-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .invite-arrow:hover {
    color: #fff;
  }

  .invite-arrow:disabled {
    opacity: 0.25;
    cursor: not-allowed;
  }

  .invite-error {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--sans);
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: #e05555;
    margin-top: 0.65rem;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .invite-error-icon {
    font-size: 0.6rem;
  }

  .invite-wrap.error .invite-divider,
  .invite-wrap.error .invite-error {
    opacity: 1;
  }

  .invite-confirm {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    margin-top: 1.25rem;
    max-width: 320px;
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .invite-confirm.visible {
    opacity: 1;
    pointer-events: all;
  }

  .invite-confirm input[type="checkbox"] {
    margin-top: 2px;
    accent-color: var(--gold);
    flex-shrink: 0;
    cursor: pointer;
  }

  .invite-confirm span {
    font-family: var(--sans);
    font-size: 0.75rem;
    font-weight: 300;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.6;
    text-align: left;
  }

  /* ── Mobile ── */
  @media (max-width: 580px) {
    .logo-img {
      height: 52px;
    }

    .hero-content h1 {
      font-size: 2.2rem;
    }

    .invite-input {
      font-size: 16px;
      letter-spacing: 0.08em;
      width: 100%;
      max-width: 85vw;
    }
  }
</style>
