  <style>

    :root {
      --black: #050505;
      --ink: #f7f2e8;
      --muted: rgba(247,242,232,.68);
      --soft: rgba(247,242,232,.42);
      --line: rgba(218,174,98,.28);
      --gold: #d6a85e;
      --gold2: #f0d6a0;
      --card: rgba(9,10,9,.72);
      --max: 1180px;
      --serif: Georgia, 'Times New Roman', serif;
      --sans: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { margin: 0; background: var(--black); color: var(--ink); font-family: var(--sans); letter-spacing: -.01em; overflow-x: hidden; }
    body:before { content: ''; position: fixed; inset: 0; pointer-events: none; z-index: 20; opacity: .10; background-image: radial-gradient(rgba(255,255,255,.45) .5px, transparent .5px); background-size: 3px 3px; mix-blend-mode: overlay; }
    a { color: inherit; text-decoration: none; }
    .site-nav { position: fixed; z-index: 30; top: 0; left: 0; right: 0; height: 104px; display: flex; align-items: center; justify-content: space-between; padding: 20px clamp(20px, 4vw, 54px); background: linear-gradient(to bottom, rgba(0,0,0,.70), rgba(0,0,0,0)); border-bottom: 1px solid transparent; transition: background .28s ease, border-color .28s ease; }
    .site-nav.is-scrolled {
      background: #050505;
      border-bottom-color: rgba(247, 242, 232, 0.09);
    }
    .logo { display: flex; align-items: center; gap: 12px; min-width: 164px; }
    .logo img { width: 132px; height: auto; display: block; }
    .nav-links { display: flex; align-items: center; gap: clamp(10px, 1.15vw, 16px); font-size: 11px; text-transform: uppercase; letter-spacing: .16em; color: rgba(247,242,232,.72); }
    .nav-links a { transition: color .25s ease; white-space: nowrap; }
    .nav-links a:hover { color: var(--gold2); }
    .nav-cta { border: 1px solid var(--line); border-radius: 999px; padding: 11px 14px; color: var(--gold2) !important; background: rgba(214,168,94,.08); }
    .hero { min-height: 100svh; position: relative; display: grid; align-items: center; padding: clamp(92px, 10vh, 124px) clamp(22px, 5vw, 72px) clamp(28px, 5vh, 52px); overflow: hidden; }
    .hero-media { position: absolute; inset: 0; z-index: 0; }
    .hero-media:after { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, rgba(0,0,0,.88) 0%, rgba(0,0,0,.52) 44%, rgba(0,0,0,.20) 100%), linear-gradient(to top, rgba(0,0,0,.88) 0%, rgba(0,0,0,.18) 42%, rgba(0,0,0,.54) 100%); }
    .hero-media img { width: 100%; height: 100%; object-fit: cover; object-position: center; display: block; }
    .hero-inner { position: relative; z-index: 2; max-width: var(--max); width: 100%; margin: 44px auto 0; display: grid; grid-template-columns: minmax(0, 1fr) minmax(310px, 360px); grid-template-rows: auto auto 44px auto auto; column-gap: clamp(28px, 4vw, 48px); row-gap: 0; align-items: start; }
    .hero-narrative { display: contents; }
    .hero-narrative .eyebrow { grid-column: 1; grid-row: 1; }
    .hero-narrative h1 { grid-column: 1; grid-row: 2; }
    .hero-narrative .hero-copy { grid-column: 1; grid-row: 4; }
    .hero-narrative .secondary-link { grid-column: 1; grid-row: 5; }
    .hero .access-card { grid-column: 2; grid-row: 4; align-self: start; margin-top: 18px; }
    .eyebrow { color: var(--gold2); text-transform: uppercase; letter-spacing: .3em; font-size: clamp(12px, .95vw, 14px); margin-bottom: 14px; }
    h1, h2, h3 { font-family: var(--serif); font-weight: 400; margin: 0; text-wrap: pretty; }
    h1 { font-size: clamp(42px, 4.45vw, 64px); line-height: .99; max-width: 780px; letter-spacing: -.055em; }
    h1 span { display: block; }
    h2 { font-size: clamp(38px, 5vw, 74px); line-height: 1.02; letter-spacing: -.045em; }
    .hero-copy { max-width: 710px; margin-top: 18px; color: rgba(247,242,232,.84); font-size: clamp(14px, 1.12vw, 16px); line-height: 1.5; }
    .access-card { border: 1px solid rgba(214,168,94,.34); background: linear-gradient(145deg, rgba(7,8,8,.88), rgba(30,23,13,.72)); box-shadow: 0 24px 60px rgba(0,0,0,.44); border-radius: 2px; padding: clamp(20px, 2.2vw, 24px); position: relative; overflow: hidden; }
    .access-card:before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, var(--gold2), transparent); opacity: .8; }
    .access-title { font-size: 13px; text-transform: uppercase; letter-spacing: .24em; color: var(--gold2); margin-bottom: 18px; }
    .input-row { display: grid; grid-template-columns: 1fr auto; border: 1px solid rgba(247,242,232,.18); background: rgba(0,0,0,.35); }
    .input-row input { min-width: 0; padding: 15px 14px; background: transparent; border: 0; color: var(--ink); outline: none; text-transform: uppercase; letter-spacing: .14em; }
    .input-row button { background: rgba(214,168,94,.14); color: var(--gold2); border: 0; border-left: 1px solid rgba(247,242,232,.14); padding: 0 18px; text-transform: uppercase; letter-spacing: .18em; font-size: 11px; }
    .small { color: rgba(247,242,232,.55); font-size: 12px; line-height: 1.55; margin-top: 14px; }
    .legal-helper, .form-notice { color: rgba(247,242,232,.60); font-size: 12px; line-height: 1.6; }
    .legal-helper { margin: 12px 0 0; }
    .form-notice { grid-column: 1 / -1; margin: -4px 0 8px; border-left: 1px solid rgba(214,168,94,.42); padding-left: 14px; }
    .legal-consent { grid-column: 1 / -1; display: grid; grid-template-columns: auto 1fr; gap: 12px; align-items: start; color: rgba(247,242,232,.70); font-size: 12px; line-height: 1.65; }
    .legal-consent input { width: 18px; height: 18px; margin-top: 2px; accent-color: var(--gold); }
    .legal-consent input:focus-visible { outline: 2px solid var(--gold2); outline-offset: 3px; }
    .legal-consent a { color: var(--gold2); text-decoration: underline; text-underline-offset: 3px; }
    .form-error { grid-column: 1 / -1; min-height: 18px; margin: 0; color: var(--gold2); font-size: 12px; line-height: 1.45; }
    .secondary-link { display: inline-flex; margin-top: 22px; color: var(--ink); border-bottom: 1px solid var(--gold); padding-bottom: 6px; font-size: 13px; letter-spacing: .12em; text-transform: uppercase; }
    section { padding: 104px clamp(22px, 5vw, 72px); position: relative; scroll-margin-top: 128px; }
    #firm { padding-top: clamp(72px, 8vh, 96px); }
    .wrap { max-width: var(--max); margin: 0 auto; }
    .split { display: grid; grid-template-columns: .85fr 1.15fr; gap: clamp(34px, 7vw, 96px); align-items: start; }
    .lead { font-size: clamp(16px, 1.55vw, 21px); line-height: 1.58; color: rgba(247,242,232,.76); margin: 0; }
    .body { color: rgba(247,242,232,.64); font-size: 15px; line-height: 1.75; }
    .rule { height: 1px; background: linear-gradient(90deg, var(--gold), transparent); opacity: .45; margin: 32px 0; }
    .cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 48px; }
    .card { border: 1px solid rgba(247,242,232,.12); background: linear-gradient(145deg, rgba(255,255,255,.045), rgba(255,255,255,.015)); padding: 28px; min-height: 220px; position: relative; }
    .card:after { content: ''; position: absolute; inset: 0; border: 1px solid rgba(214,168,94,.08); transform: translate(5px, 5px); pointer-events: none; }
    .card h3 { font-size: 27px; line-height: 1.05; margin-bottom: 22px; }
    .card p { color: rgba(247,242,232,.62); line-height: 1.68; margin: 0 0 12px; }
    .section-intro { max-width: 900px; margin-top: 24px; }
    .process-line { position: relative; display: grid; grid-template-columns: repeat(5, 1fr); gap: 20px; margin-top: 54px; padding-top: 30px; }
    .process-line:before { content: ''; position: absolute; left: 0; right: 0; top: 10px; height: 1px; background: linear-gradient(90deg, rgba(214,168,94,.78), rgba(214,168,94,.16)); }
    .process-step { position: relative; padding-right: 18px; }
    .process-step:before { content: ''; position: absolute; top: -25px; left: 0; width: 9px; height: 9px; border-radius: 999px; background: var(--gold2); box-shadow: 0 0 0 6px rgba(214,168,94,.08); }
    .process-step span { display: block; color: var(--gold2); letter-spacing: .18em; font-size: 11px; margin-bottom: 18px; }
    .process-step h3 { font-size: 24px; line-height: 1.05; margin-bottom: 14px; }
    .process-step p { color: rgba(247,242,232,.62); line-height: 1.62; margin: 0; font-size: 14px; }
    .dark-band { background: radial-gradient(circle at 18% 12%, rgba(214,168,94,.16), transparent 32%), linear-gradient(180deg, #050505, #0b0907); }
    .leadership-points { list-style: none; padding: 0; margin: 38px 0 0; display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 18px 28px; }
    .leadership-points li { border-top: 1px solid rgba(214,168,94,.36); padding-top: 14px; color: rgba(247,242,232,.72); line-height: 1.55; }
    .intelligence-field-section {
      background: linear-gradient(180deg, #050505 0%, #070604 52%, #050505 100%);
      overflow: clip;
    }
    .intelligence-field-shell { max-width: min(1360px, 100%); margin: 0 auto; width: 100%; }
    .intelligence-field-header {
      max-width: var(--max);
      margin: 0 auto clamp(34px, 5vh, 58px);
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(280px, 360px);
      gap: clamp(28px, 6vw, 120px);
      align-items: start;
    }
    .intelligence-field-header .eyebrow { margin-bottom: 14px; }
    .intelligence-field-header h2 { max-width: 640px; font-size: clamp(42px, 4.5vw, 64px); line-height: .96; letter-spacing: -.045em; }
    .intelligence-field-header .lead { margin: 0; color: rgba(247,242,232,.56); font-size: 14px; line-height: 1.55; max-width: 360px; }
    .qualification-architecture {
      position: relative;
      isolation: isolate;
      min-height: clamp(540px, 48vw, 620px);
      padding: clamp(28px, 3vw, 42px) clamp(24px, 3vw, 34px) clamp(24px, 2.6vw, 34px);
      border-top: 1px solid rgba(247,242,232,.06);
      border-bottom: 1px solid rgba(247,242,232,.05);
      background:
        radial-gradient(circle at 13% 34%, rgba(214,168,94,.06), transparent 30%),
        radial-gradient(circle at 52% 42%, rgba(214,168,94,.032), transparent 24%),
        radial-gradient(circle at 84% 40%, rgba(247,242,232,.022), transparent 25%),
        linear-gradient(90deg, rgba(247,242,232,.026), transparent 22%, transparent 76%, rgba(247,242,232,.014));
    }
    .qualification-architecture:before {
      content: '';
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      opacity: .24;
      background-image:
        linear-gradient(rgba(247,242,232,.028) 1px, transparent 1px),
        linear-gradient(90deg, rgba(247,242,232,.022) 1px, transparent 1px);
      background-size: 96px 96px, 96px 96px;
      mask-image: linear-gradient(to bottom, transparent, #000 15%, #000 82%, transparent);
    }
    .qualification-architecture:after {
      content: '';
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      opacity: .24;
      mix-blend-mode: screen;
      background-image:
        radial-gradient(circle at 22% 18%, rgba(255,255,255,.08) 0 1px, transparent 1.2px),
        radial-gradient(circle at 76% 62%, rgba(214,168,94,.055) 0 1px, transparent 1.2px);
      background-size: 34px 34px, 47px 47px;
      filter: blur(.15px);
    }
    .qualification-backdrop {
      position: absolute;
      inset: 0;
      z-index: 1;
      width: 100%;
      height: 100%;
      pointer-events: none;
      overflow: visible;
    }
    .qa-contours { fill: none; stroke: rgba(247,242,232,.052); stroke-width: 1; stroke-linecap: round; stroke-linejoin: round; }
    .qa-boundaries { fill: none; stroke: rgba(214,168,94,.11); stroke-width: 1; stroke-linecap: round; stroke-linejoin: round; }
    .qa-analytical { fill: none; stroke: rgba(214,168,94,.14); stroke-width: 1; stroke-linecap: round; stroke-linejoin: round; }
    .density-market { fill: rgba(214,168,94,.20); }
    .density-lenses { fill: rgba(214,168,94,.16); }
    .density-qualified { fill: rgba(214,168,94,.12); }
    .qualification-stages {
      position: relative;
      z-index: 2;
      min-height: clamp(488px, 42vw, 552px);
      display: grid;
      grid-template-columns: minmax(0,1.02fr) minmax(0,1.22fr) minmax(0,1.04fr);
      column-gap: clamp(34px, 4.1vw, 56px);
      align-items: stretch;
    }
    .qualification-stage { position: relative; min-width: 0; padding: 34px 0 30px; }
    .qualification-stage + .qualification-stage:before {
      content: '';
      position: absolute;
      left: calc(clamp(34px, 4.1vw, 56px) / -2);
      top: 24px;
      bottom: 24px;
      width: 1px;
      background: linear-gradient(to bottom, transparent, rgba(214,168,94,.15), rgba(247,242,232,.065), transparent);
    }
    .qualification-stage-title {
      position: relative;
      z-index: 3;
      display: inline-block;
      margin: 0;
      padding: 7px 18px 7px 0;
      color: rgba(214,168,94,.84);
      background: linear-gradient(90deg, rgba(5,5,5,.98), rgba(5,5,5,.90) 82%, transparent);
      font-size: 12px;
      font-weight: 500;
      letter-spacing: .22em;
      line-height: 1;
      text-transform: uppercase;
      white-space: nowrap;
    }
    .qa-register, .qa-conditions { position: relative; z-index: 3; margin: 42px 0 0; padding: 0; list-style: none; }
    .qa-market-register { display: grid; gap: 24px; max-width: 318px; }
    .qa-register li, .qa-conditions li {
      position: relative;
      color: rgba(247,242,232,.62);
      font-size: clamp(10.5px, .72vw, 12px);
      letter-spacing: .20em;
      line-height: 1.35;
      text-transform: uppercase;
    }
    .qa-market-register li {
      width: max-content;
      max-width: 100%;
      padding-left: 36px;
      padding-right: 16px;
      background: linear-gradient(90deg, rgba(5,5,5,.96), rgba(5,5,5,.88) 88%, transparent);
    }
    .qa-market-register li:before {
      content: '';
      position: absolute;
      left: 0;
      top: .64em;
      width: 20px;
      height: 1px;
      background: linear-gradient(90deg, rgba(214,168,94,.62), rgba(214,168,94,.12));
    }
    .qa-market-register li:nth-child(2n) { margin-left: 22px; color: rgba(247,242,232,.52); }
    .qa-market-register li:nth-child(3n) { margin-left: 8px; }
    .qa-lens-register { margin-top: 40px; display: grid; gap: 27px; max-width: 430px; }
    .qa-lens-register li {
      width: max-content;
      max-width: 100%;
      padding-left: 54px;
      padding-right: 18px;
      color: rgba(247,242,232,.74);
      background: linear-gradient(90deg, rgba(5,5,5,.97), rgba(5,5,5,.90) 84%, transparent);
      font-weight: 700;
      letter-spacing: .19em;
    }
    .qa-lens-register li:before {
      content: '';
      position: absolute;
      left: 0;
      top: .65em;
      width: 32px;
      height: 1px;
      background: rgba(214,168,94,.74);
    }
    .qa-lens-register li:after {
      content: '';
      position: absolute;
      left: 36px;
      top: calc(.65em - 2px);
      width: 5px;
      height: 5px;
      border: 1px solid rgba(214,168,94,.68);
      border-radius: 50%;
      background: #050505;
    }
    .qa-qualified-stage { padding-left: 10px; }
    .qa-conditions { margin-top: 54px; display: grid; gap: clamp(34px, 4vw, 54px); max-width: 100%; }
    .qa-conditions li {
      width: 100%;
      max-width: 100%;
      padding-left: 48px;
      padding-right: 12px;
      color: rgba(247,242,232,.70);
      background: linear-gradient(90deg, rgba(5,5,5,.97), rgba(5,5,5,.88) 84%, transparent);
      font-size: clamp(10px, .70vw, 12px);
      letter-spacing: clamp(.10em, .78vw, .18em);
      line-height: 1.55;
      white-space: normal;
      overflow: visible;
      overflow-wrap: normal;
      word-break: normal;
    }
    .qa-conditions li:before {
      content: '';
      position: absolute;
      left: 0;
      top: .6em;
      width: 15px;
      height: 15px;
      border: 1px solid rgba(214,168,94,.84);
      border-radius: 50%;
      background: #050505;
      box-shadow: 0 0 0 5px rgba(214,168,94,.025);
    }
    .qa-conditions li:after {
      content: '';
      position: absolute;
      left: 24px;
      right: 0;
      top: calc(.6em + 7px);
      z-index: -1;
      height: 1px;
      background: linear-gradient(90deg, rgba(214,168,94,.34), rgba(247,242,232,.05), transparent);
      transform: translateY(-50%);
    }
    .qa-output-note {
      position: absolute;
      left: 58px;
      right: 12px;
      bottom: 32px;
      z-index: 3;
      max-width: 350px;
      margin: 0;
      padding: 8px 12px 8px 0;
      color: rgba(247,242,232,.60);
      background: linear-gradient(90deg, rgba(5,5,5,.96), rgba(5,5,5,.86) 80%, transparent);
      font-size: 14px;
      font-weight: 400;
      line-height: 1.45;
    }
    .governance-note {
      max-width: 760px;
      margin: clamp(24px, 4vh, 40px) 0 0 auto;
      color: rgba(247,242,232,.60);
      font-size: 14px;
      font-weight: 400;
      line-height: 1.7;
    }
    @media (max-width: 1280px) {
      .qualification-architecture { padding-inline: 22px; }
      .qualification-stages { column-gap: 32px; grid-template-columns: minmax(0,.96fr) minmax(0,1.04fr) minmax(0,1.16fr); }
      .qualification-stage + .qualification-stage:before { left: -16px; }
      .qa-market-register { gap: 20px; }
      .qa-lens-register { gap: 24px; }
      .qa-conditions li { font-size: 10.5px; letter-spacing: .11em; line-height: 1.5; }
    }
    @media (max-width: 980px) {
      .intelligence-field-section { padding: 125px clamp(22px, 5vw, 72px) 72px; }
      .intelligence-field-header { grid-template-columns: 1fr; gap: 18px; margin-bottom: 32px; }
      .intelligence-field-header h2 { font-size: clamp(38px, 10vw, 58px); }
      .qualification-architecture { min-height: 0; padding: 22px 18px 24px; }
      .qualification-architecture:before { opacity: .15; background-size: 82px 82px, 82px 82px; }
      .qualification-backdrop { opacity: .58; }
      .density-market { opacity: .62; }
      .density-lenses { opacity: .42; }
      .density-qualified { opacity: .18; }
      .qa-contours { opacity: .50; }
      .qa-boundaries, .qa-analytical { opacity: .38; }
      .qualification-stages { min-height: 0; display: grid; grid-template-columns: 1fr; row-gap: 0; }
      .qualification-stage { padding: 22px 0 24px; }
      .qualification-stage + .qualification-stage:before { left: 0; top: 0; right: 0; bottom: auto; width: auto; height: 1px; background: linear-gradient(90deg, transparent, rgba(214,168,94,.13), transparent); }
      .qualification-stage-title { font-size: 10px; letter-spacing: .22em; }
      .qa-register, .qa-conditions { margin-top: 18px; }
      .qa-market-register, .qa-lens-register { gap: 12px; max-width: none; }
      .qa-market-register li { margin-left: 0 !important; padding-left: 30px; }
      .qa-market-register li:before { width: 18px; }
      .qa-register li { font-size: 9.8px; letter-spacing: .16em; line-height: 1.32; }
      .qa-lens-register li { padding-left: 42px; font-size: 9.5px; letter-spacing: .14em; }
      .qa-lens-register li:before { width: 28px; }
      .qa-lens-register li:after { left: 32px; }
      .qa-qualified-stage { padding-left: 0; }
      .qa-conditions { gap: 18px; max-width: none; }
      .qa-conditions li { padding-left: 38px; padding-right: 4px; font-size: 9.2px; letter-spacing: .095em; line-height: 1.35; }
      .qa-conditions li:before { width: 12px; height: 12px; top: .45em; }
      .qa-conditions li:after { left: 20px; top: calc(.45em + 6px); }
