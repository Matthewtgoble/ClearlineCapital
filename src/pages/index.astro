<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Clearline Capital | Private Investment and Acquisition Firm</title>
  <meta name="description" content="Clearline Capital pursues founder-led businesses, select real estate, and operating partnerships through proprietary origination, disciplined underwriting, and agentic intelligence." />
  <meta property="og:title" content="Clearline Capital" />
  <meta property="og:description" content="A private investment and acquisition firm pursuing off-market business acquisitions, select real estate opportunities, and operating partnerships." />
  <link rel="preload" as="image" href="/hero-clearline-1440.webp" imagesrcset="/hero-clearline-960.webp 960w, /hero-clearline-1440.webp 1440w, /hero-clearline-1920.webp 1920w" imagesizes="100vw" fetchpriority="high" />
  <style>

    :root {
      --black: #050505;
      --ink: #f7f2e8;
      --muted: rgba(247,242,232,.68);
      --soft: rgba(247,242,232,.42);
      --line: rgba(218,174,98,.28);
      --gold: #d6a85e;
      --gold2: #f0d6a0;
      --card: rgba(9,10,9,.72);
      --max: 1180px;
      --serif: Georgia, 'Times New Roman', serif;
      --sans: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { margin: 0; background: var(--black); color: var(--ink); font-family: var(--sans); letter-spacing: -.01em; overflow-x: hidden; }
    body:before { content: ''; position: fixed; inset: 0; pointer-events: none; z-index: 20; opacity: .10; background-image: radial-gradient(rgba(255,255,255,.45) .5px, transparent .5px); background-size: 3px 3px; mix-blend-mode: overlay; }
    a { color: inherit; text-decoration: none; }
    .site-nav { position: fixed; z-index: 30; top: 0; left: 0; right: 0; height: 104px; display: flex; align-items: center; justify-content: space-between; padding: 20px clamp(20px, 4vw, 54px); background: linear-gradient(to bottom, rgba(0,0,0,.70), rgba(0,0,0,0)); border-bottom: 1px solid transparent; transition: background .28s ease, border-color .28s ease; }
    .site-nav.is-scrolled {
      background: #050505;
      border-bottom-color: rgba(247, 242, 232, 0.09);
    }
    .logo { display: flex; align-items: center; gap: 12px; min-width: 164px; }
    .logo img { width: 132px; height: auto; display: block; }
    .nav-links { display: flex; align-items: center; gap: clamp(10px, 1.15vw, 16px); font-size: 11px; text-transform: uppercase; letter-spacing: .16em; color: rgba(247,242,232,.72); }
    .nav-links a { transition: color .25s ease; white-space: nowrap; }
    .nav-links a:hover { color: var(--gold2); }
    .nav-cta { border: 1px solid var(--line); border-radius: 999px; padding: 11px 14px; color: var(--gold2) !important; background: rgba(214,168,94,.08); }
    .hero { min-height: 100svh; position: relative; display: grid; align-items: center; padding: clamp(92px, 10vh, 124px) clamp(22px, 5vw, 72px) clamp(28px, 5vh, 52px); overflow: hidden; }
    .hero-media { position: absolute; inset: 0; z-index: 0; }
    .hero-media:after { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, rgba(0,0,0,.88) 0%, rgba(0,0,0,.52) 44%, rgba(0,0,0,.20) 100%), linear-gradient(to top, rgba(0,0,0,.88) 0%, rgba(0,0,0,.18) 42%, rgba(0,0,0,.54) 100%); }
    .hero-media img { width: 100%; height: 100%; object-fit: cover; object-position: center; display: block; }
    .hero-inner { position: relative; z-index: 2; max-width: var(--max); width: 100%; margin: 44px auto 0; display: grid; grid-template-columns: minmax(0, 1fr) minmax(310px, 360px); grid-template-rows: auto auto 44px auto auto; column-gap: clamp(28px, 4vw, 48px); row-gap: 0; align-items: start; }
    .hero-narrative { display: contents; }
    .hero-narrative .eyebrow { grid-column: 1; grid-row: 1; }
    .hero-narrative h1 { grid-column: 1; grid-row: 2; }
    .hero-narrative .hero-copy { grid-column: 1; grid-row: 4; }
    .hero-narrative .secondary-link { grid-column: 1; grid-row: 5; }
    .hero .access-card { grid-column: 2; grid-row: 4; align-self: start; margin-top: 18px; }
    .eyebrow { color: var(--gold2); text-transform: uppercase; letter-spacing: .3em; font-size: clamp(12px, .95vw, 14px); margin-bottom: 14px; }
    h1, h2, h3 { font-family: var(--serif); font-weight: 400; margin: 0; text-wrap: pretty; }
    h1 { font-size: clamp(42px, 4.45vw, 64px); line-height: .99; max-width: 780px; letter-spacing: -.055em; }
    h1 span { display: block; }
    h2 { font-size: clamp(38px, 5vw, 74px); line-height: 1.02; letter-spacing: -.045em; }
    .hero-copy { max-width: 710px; margin-top: 18px; color: rgba(247,242,232,.84); font-size: clamp(14px, 1.12vw, 16px); line-height: 1.5; }
    .access-card { border: 1px solid rgba(214,168,94,.34); background: linear-gradient(145deg, rgba(7,8,8,.88), rgba(30,23,13,.72)); box-shadow: 0 24px 60px rgba(0,0,0,.44); border-radius: 2px; padding: clamp(20px, 2.2vw, 24px); position: relative; overflow: hidden; }
    .access-card:before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, var(--gold2), transparent); opacity: .8; }
    .access-title { font-size: 13px; text-transform: uppercase; letter-spacing: .24em; color: var(--gold2); margin-bottom: 18px; }
    .input-row { display: grid; grid-template-columns: 1fr auto; border: 1px solid rgba(247,242,232,.18); background: rgba(0,0,0,.35); }
    .input-row input { min-width: 0; padding: 15px 14px; background: transparent; border: 0; color: var(--ink); outline: none; text-transform: uppercase; letter-spacing: .14em; }
    .input-row button { background: rgba(214,168,94,.14); color: var(--gold2); border: 0; border-left: 1px solid rgba(247,242,232,.14); padding: 0 18px; text-transform: uppercase; letter-spacing: .18em; font-size: 11px; }
    .small { color: rgba(247,242,232,.55); font-size: 12px; line-height: 1.55; margin-top: 14px; }
    .secondary-link { display: inline-flex; margin-top: 22px; color: var(--ink); border-bottom: 1px solid var(--gold); padding-bottom: 6px; font-size: 13px; letter-spacing: .12em; text-transform: uppercase; }
    section { padding: 104px clamp(22px, 5vw, 72px); position: relative; scroll-margin-top: 128px; }
    #firm { padding-top: clamp(72px, 8vh, 96px); }
    .wrap { max-width: var(--max); margin: 0 auto; }
    .split { display: grid; grid-template-columns: .85fr 1.15fr; gap: clamp(34px, 7vw, 96px); align-items: start; }
    .lead { font-size: clamp(16px, 1.55vw, 21px); line-height: 1.58; color: rgba(247,242,232,.76); margin: 0; }
    .body { color: rgba(247,242,232,.64); font-size: 15px; line-height: 1.75; }
    .rule { height: 1px; background: linear-gradient(90deg, var(--gold), transparent); opacity: .45; margin: 32px 0; }
    .cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 48px; }
    .card { border: 1px solid rgba(247,242,232,.12); background: linear-gradient(145deg, rgba(255,255,255,.045), rgba(255,255,255,.015)); padding: 28px; min-height: 220px; position: relative; }
    .card:after { content: ''; position: absolute; inset: 0; border: 1px solid rgba(214,168,94,.08); transform: translate(5px, 5px); pointer-events: none; }
    .card h3 { font-size: 27px; line-height: 1.05; margin-bottom: 22px; }
    .card p { color: rgba(247,242,232,.62); line-height: 1.68; margin: 0 0 12px; }
    .section-intro { max-width: 900px; margin-top: 24px; }
    .process-line { position: relative; display: grid; grid-template-columns: repeat(5, 1fr); gap: 20px; margin-top: 54px; padding-top: 30px; }
    .process-line:before { content: ''; position: absolute; left: 0; right: 0; top: 10px; height: 1px; background: linear-gradient(90deg, rgba(214,168,94,.78), rgba(214,168,94,.16)); }
    .process-step { position: relative; padding-right: 18px; }
    .process-step:before { content: ''; position: absolute; top: -25px; left: 0; width: 9px; height: 9px; border-radius: 999px; background: var(--gold2); box-shadow: 0 0 0 6px rgba(214,168,94,.08); }
    .process-step span { display: block; color: var(--gold2); letter-spacing: .18em; font-size: 11px; margin-bottom: 18px; }
    .process-step h3 { font-size: 24px; line-height: 1.05; margin-bottom: 14px; }
    .process-step p { color: rgba(247,242,232,.62); line-height: 1.62; margin: 0; font-size: 14px; }
    .dark-band { background: radial-gradient(circle at 18% 12%, rgba(214,168,94,.16), transparent 32%), linear-gradient(180deg, #050505, #0b0907); }
    .leadership-points { list-style: none; padding: 0; margin: 38px 0 0; display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 18px 28px; }
    .leadership-points li { border-top: 1px solid rgba(214,168,94,.36); padding-top: 14px; color: rgba(247,242,232,.72); line-height: 1.55; }
    .intelligence-field-section {
      background: linear-gradient(180deg, #050505 0%, #070604 52%, #050505 100%);
      overflow: clip;
    }
    .intelligence-field-shell { max-width: min(1360px, 100%); margin: 0 auto; width: 100%; }
    .intelligence-field-header {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(280px, 360px);
      gap: clamp(28px, 6vw, 120px);
      align-items: start;
      margin-bottom: clamp(34px, 5vh, 58px);
    }
    .intelligence-field-header .eyebrow { margin-bottom: 14px; }
    .intelligence-field-header h2 { max-width: 640px; font-size: clamp(42px, 4.5vw, 64px); line-height: .96; letter-spacing: -.045em; }
    .intelligence-field-header .lead { margin: 0; color: rgba(247,242,232,.56); font-size: 14px; line-height: 1.55; max-width: 360px; }
    .qualification-architecture {
      position: relative;
      border: 1px solid rgba(247,242,232,.08);
      padding: clamp(24px, 3vw, 36px);
      background:
        linear-gradient(90deg, rgba(214,168,94,.028) 1px, transparent 1px),
        linear-gradient(180deg, rgba(214,168,94,.022) 1px, transparent 1px),
        linear-gradient(180deg, rgba(247,242,232,.012), rgba(247,242,232,.004));
      background-size: 84px 84px, 84px 84px, auto;
    }
    .qualification-architecture:before {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 32% 28%, rgba(214,168,94,.045), transparent 30%),
        radial-gradient(circle at 66% 46%, rgba(214,168,94,.035), transparent 34%);
      opacity: .8;
    }
    .qualification-panels { position: relative; z-index: 2; display: grid; grid-template-columns: minmax(0,.95fr) minmax(0,1.14fr) minmax(0,.96fr); gap: clamp(18px, 1.7vw, 24px); }
    .qualification-panel { position: relative; min-width: 0; min-height: 575px; padding: 0; border: 1px solid rgba(247,242,232,.11); background: rgba(5,5,5,.78); box-shadow: inset 0 0 0 1px rgba(214,168,94,.035); }
    .qualification-panel:before { content: ''; position: absolute; inset: 0; pointer-events: none; background: linear-gradient(180deg, rgba(247,242,232,.025), transparent 32%, rgba(214,168,94,.018)); }
    .qa-panel-heading { position: relative; z-index: 2; min-height: 68px; display: grid; grid-template-columns: auto minmax(0, 1fr) auto; align-items: center; gap: 12px; padding: 0 clamp(14px, 1.4vw, 20px); border-bottom: 1px solid rgba(247,242,232,.09); background: rgba(247,242,232,.025); }
    .qa-panel-heading h3 { margin: 0; color: rgba(247,242,232,.88); font-size: clamp(8.5px, .72vw, 10.5px); font-weight: 500; letter-spacing: .20em; line-height: 1; text-transform: uppercase; white-space: nowrap; min-width: 0; }
    .qa-panel-kicker { justify-self: end; color: rgba(247,242,232,.28); font-size: clamp(7px, .55vw, 8.5px); letter-spacing: .14em; text-transform: uppercase; white-space: nowrap; }
    .qa-icon { width: 17px; height: 17px; position: relative; opacity: .82; }
    .qa-icon.market:before, .qa-icon.market:after { content: ''; position: absolute; left: 2px; right: 2px; height: 1px; background: rgba(214,168,94,.56); }
    .qa-icon.market:before { top: 5px; box-shadow: 0 4px 0 rgba(214,168,94,.38), 0 8px 0 rgba(214,168,94,.22); }
    .qa-icon.market:after { top: 2px; width: 7px; box-shadow: 0 4px 0 rgba(214,168,94,.32), 0 8px 0 rgba(214,168,94,.18); }
    .qa-icon.lens { border: 1px solid rgba(240,214,160,.8); border-radius: 999px; box-shadow: 0 0 0 5px rgba(214,168,94,.045); }
    .qa-icon.output { transform: rotate(45deg); border: 1px solid rgba(240,214,160,.78); width: 12px; height: 12px; margin-left: 3px; }
    .qa-market-list, .qa-lens-list, .qa-output-list { position: relative; z-index: 2; list-style: none; margin: 0; padding: 28px 24px; }
    .qa-market-list { display: grid; gap: 0; }
    .qa-market-list li { display: grid; grid-template-columns: 24px 1fr; align-items: center; min-height: 56px; border-bottom: 1px solid rgba(247,242,232,.055); color: rgba(247,242,232,.58); font-size: 11px; letter-spacing: .22em; text-transform: uppercase; }
    .market-line-icon { width: 14px; height: 12px; position: relative; opacity: .58; }
    .market-line-icon:before { content: ''; position: absolute; left: 0; top: 1px; width: 12px; height: 1px; background: rgba(214,168,94,.38); box-shadow: 0 4px 0 rgba(214,168,94,.28), 0 8px 0 rgba(214,168,94,.18); }
    .qa-lens-list { padding-top: 22px; padding-bottom: 22px; display: grid; gap: 11px; }
    .qa-lens-list:before { content: ''; position: absolute; left: 42px; top: 40px; bottom: 48px; width: 1px; background: linear-gradient(180deg, transparent, rgba(214,168,94,.32), transparent); }
    .qa-lens-list li { position: relative; min-height: 58px; display: flex; align-items: center; padding: 0 24px 0 50px; border: 1px solid rgba(247,242,232,.07); background: linear-gradient(180deg, rgba(247,242,232,.035), rgba(247,242,232,.015)); color: rgba(247,242,232,.88); font-size: 12px; font-weight: 700; letter-spacing: .20em; text-transform: uppercase; }
    .qa-lens-list li:before { content: ''; position: absolute; left: 12px; top: 50%; width: 12px; height: 12px; border: 1px solid rgba(240,214,160,.82); border-radius: 999px; background: #050505; box-shadow: 0 0 0 4px rgba(214,168,94,.045); transform: translateY(-50%); }
    .qa-output-list { padding-top: 32px; display: grid; gap: 0; }
    .qa-output-list:before { content: ''; position: absolute; left: 32px; top: 38px; height: 220px; width: 1px; background: linear-gradient(180deg, rgba(214,168,94,.26), rgba(214,168,94,.06)); }
    .qa-output-list li { position: relative; display: grid; grid-template-columns: 28px 1fr; align-items: start; min-height: 92px; border-bottom: 1px solid rgba(247,242,232,.065); color: rgba(247,242,232,.62); font-size: 11px; letter-spacing: .18em; line-height: 1.55; text-transform: uppercase; }
    .output-diamond { width: 11px; height: 11px; margin-top: 5px; border: 1px solid rgba(240,214,160,.74); background: #050505; transform: rotate(45deg); box-shadow: 0 0 0 4px rgba(214,168,94,.035); }
    .qa-output-note { position: relative; z-index: 2; margin: 34px 24px 0; padding-top: 26px; border-top: 1px solid rgba(247,242,232,.055); color: rgba(247,242,232,.62); font-size: 13px; line-height: 1.45; max-width: 300px; }
    .qa-connector { position: absolute; z-index: 3; top: 98px; bottom: 118px; width: 26px; pointer-events: none; }
    .qa-connector.left { left: calc(33.333% - 17px); }
    .qa-connector.right { left: calc(66.666% - 8px); }
    .qa-connector:before, .qa-connector:after { content: ''; position: absolute; top: 20px; bottom: 0; width: 1px; background: linear-gradient(180deg, transparent, rgba(214,168,94,.25), transparent); }
    .qa-connector:before { left: 5px; } .qa-connector:after { right: 5px; }
    .qa-node { position: absolute; left: 50%; width: 4px; height: 4px; margin-left: -2px; border-radius: 50%; background: rgba(214,168,94,.72); box-shadow: 0 0 0 3px rgba(214,168,94,.05); }
    .qa-node.n1 { top: 30%; } .qa-node.n2 { top: 50%; } .qa-node.n3 { top: 70%; }
    .qa-connector-line { position: absolute; left: 0; right: 0; height: 1px; background: rgba(214,168,94,.14); }
    .qa-connector-line.l1 { top: 30%; } .qa-connector-line.l2 { top: 50%; } .qa-connector-line.l3 { top: 70%; }
    .governance-note { max-width: 760px; margin: clamp(24px, 4vh, 40px) 0 0 auto; color: rgba(247,242,232,.62); font-size: 14px; line-height: 1.7; }
    .intelligence-reduced-copy { position: absolute; left: -9999px; }
    @media (max-width: 980px) {
      .intelligence-field-section { padding: 84px 20px 72px; }
      .intelligence-field-header { grid-template-columns: 1fr; gap: 18px; margin-bottom: 32px; }
      .intelligence-field-header h2 { font-size: clamp(38px, 10vw, 58px); }
      .intelligence-field-header .lead { max-width: 520px; }
      .qualification-architecture { padding: 18px; }
      .qualification-panels { grid-template-columns: 1fr; gap: 16px; }
      .qualification-panel { min-height: auto; }
      .qa-panel-heading { min-height: 62px; }
      .qa-panel-kicker { display: none; }
      .qa-market-list, .qa-lens-list, .qa-output-list { padding: 20px 18px; }
      .qa-market-list li { min-height: 48px; }
      .qa-lens-list li { min-height: 54px; font-size: 11px; letter-spacing: .16em; }
      .qa-output-list li { min-height: 78px; font-size: 10.5px; }
      .qa-connector { display: none; }
      .governance-note { margin: 26px 0 0; font-size: 13px; }
    }
    @media (prefers-reduced-motion: reduce) {
      * { animation: none !important; transition: none !important; scroll-behavior: auto !important; }
    }

    .access-section { background: linear-gradient(180deg, #050505, #090705); }
    .hidden { display: none; }
    .form-shell { margin-top: 36px; display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .field, textarea { border: 1px solid rgba(247,242,232,.13); background: rgba(247,242,232,.035); padding: 15px 14px; color: var(--ink); min-height: 52px; font: inherit; outline: none; }
    textarea { grid-column: 1 / -1; min-height: 122px; resize: vertical; }
    .submit { grid-column: 1 / -1; justify-self: start; border: 1px solid rgba(214,168,94,.42); background: rgba(214,168,94,.12); color: var(--gold2); padding: 14px 22px; text-transform: uppercase; letter-spacing: .18em; font-size: 12px; }
    footer { padding: 48px clamp(22px, 5vw, 72px); border-top: 1px solid rgba(247,242,232,.1); color: rgba(247,242,232,.62); }
    footer .wrap { display: flex; justify-content: space-between; gap: 20px; font-size: 12px; letter-spacing: .08em; text-transform: uppercase; }
    @media (max-width: 1180px) { .nav-links { gap: 10px; font-size: 10px; letter-spacing: .12em; } .logo { min-width: 132px; } }
    @media (max-width: 980px) {
      .hero-inner, .split { grid-template-columns: 1fr; }
      .hero-inner { display: grid; grid-template-rows: auto; row-gap: 22px; margin: 0 auto; }
      .hero-narrative { display: block; padding-top: 0; }
      .hero .access-card { grid-column: auto; grid-row: auto; }
      .access-card { max-width: 480px; }
      .cards, .leadership-points { grid-template-columns: 1fr; }
      .process-line { grid-template-columns: 1fr; gap: 0; margin-top: 42px; padding: 0 0 0 24px; }
      .process-line:before { left: 4px; right: auto; top: 2px; bottom: 6px; width: 1px; height: auto; background: linear-gradient(180deg, rgba(214,168,94,.78), rgba(214,168,94,.16)); }
      .process-step { padding: 0 0 28px; }
      .process-step:before { top: 3px; left: -24px; width: 8px; height: 8px; }
      .process-step span { margin-bottom: 8px; }
      .process-step h3 { font-size: 22px; margin-bottom: 8px; }
      .process-step p { font-size: 13px; line-height: 1.55; max-width: 620px; }
      .nav-links { display: none; }
    }
    @media (max-width: 620px) {
      .site-nav {
        position: sticky;
        height: 72px;
        padding: 8px 18px 7px;
        background: #050505;
        border-bottom: 1px solid rgba(247, 242, 232, 0.08);
      }
      .logo img { width: 98px; }
      .hero { min-height: calc(100svh - 72px); padding: 28px 20px 26px; }
      .hero-inner { gap: 22px; }
      .hero-copy { margin-top: 14px; font-size: 13px; line-height: 1.42; }
      .hero .secondary-link { margin-top: 16px; }
      .access-card { padding: 17px; }
      .access-title { margin-bottom: 12px; }
      .input-row input { padding: 12px 11px; }
      .input-row button { padding: 0 12px; }
      .small { margin-top: 10px; line-height: 1.42; }
      section { padding: 72px 20px; scroll-margin-top: 96px; }
      .form-shell { grid-template-columns: 1fr; }
      textarea, .submit { grid-column: auto; }
      h1 { font-size: clamp(37px, 11.3vw, 44px); line-height: .98; }
      footer .wrap { flex-direction: column; }
    }
    @media (prefers-reduced-motion: reduce) {
      * { animation: none !important; scroll-behavior: auto !important; }
    }

  </style>
</head>
<body>
  <nav class="site-nav" aria-label="Primary navigation">
    <a class="logo" href="#top" aria-label="Clearline Capital home"><img src="/logo-champagne-132.webp" srcset="/logo-champagne-132.webp 132w, /logo-champagne-264.webp 264w, /logo-champagne-528.webp 528w" sizes="132px" width="132" height="83" alt="Clearline Capital" /></a>
    <div class="nav-links">
      <a href="#firm">Firm</a>
      <a href="#focus">Investment Focus</a>
      <a href="#process">Process</a>
      <a href="#network">Network</a>
      <a href="#intelligence">Intelligence</a>
      <a href="#access" class="nav-cta">Request Consideration</a>
    </div>
  </nav>

  <main id="top">
    <header class="hero">
      <picture class="hero-media" aria-hidden="true">
        <source type="image/avif" srcset="/hero-clearline-960.avif 960w, /hero-clearline-1440.avif 1440w, /hero-clearline-1920.avif 1920w" sizes="100vw" />
        <source type="image/webp" srcset="/hero-clearline-960.webp 960w, /hero-clearline-1440.webp 1440w, /hero-clearline-1920.webp 1920w" sizes="100vw" />
        <img src="/hero-clearline-1440.webp" srcset="/hero-clearline-960.webp 960w, /hero-clearline-1440.webp 1440w, /hero-clearline-1920.webp 1920w" sizes="100vw" width="1440" height="810" alt="" fetchpriority="high" decoding="sync" />
      </picture>
      <div class="hero-inner">
        <div class="hero-narrative">
          <div class="eyebrow">PRIVATE INVESTMENT AND ACQUISITION FIRM</div>
          <h1>Off-market acquisitions, informed by proprietary intelligence.</h1>
          <p class="hero-copy">Clearline Capital pursues founder-led businesses, select real estate, and operating partnerships through direct relationships, disciplined underwriting, and a purpose-built agentic intelligence platform that expands the firm’s off-market origination and research capabilities.</p>
          <a class="secondary-link" href="#firm">Enter the overview</a>
        </div>
        <aside class="access-card" aria-label="Invitation access validation">
          <div class="access-title">Invitation access</div>
          <div class="input-row">
            <input id="invite-code" aria-label="Invitation code" placeholder="Invitation code" autocomplete="off" />
            <button id="invite-submit" type="button">Submit</button>
          </div>
          <p class="small">Access is reserved for relevant opportunities and trusted introductions.</p>
          <a class="secondary-link" href="#access">Request consideration</a>
        </aside>
      </div>
    </header>

    <section id="firm">
      <div class="wrap split">
        <div>
          <div class="eyebrow">THE FIRM</div>
          <h2>A disciplined platform for off-market acquisitions.</h2>
        </div>
        <div>
          <p class="lead">Clearline Capital identifies and evaluates select businesses, real estate, and operating partnerships outside broadly marketed channels.</p>
          <div class="rule"></div>
          <p class="body">The firm combines sector research, proprietary market intelligence, and experienced investor and operator perspective to develop conviction around a limited number of qualified situations.</p>
          <p class="body">Each opportunity is tested through financial analysis, professional diligence, operating insight, and a clearly defined path to execution.</p>
        </div>
      </div>
    </section>

    <section id="focus">
      <div class="wrap">
        <div class="eyebrow">INVESTMENT FOCUS</div>
        <h2>Where Clearline Capital invests.</h2>
        <div class="cards">
          <article class="card"><h3>Founder-led and privately held businesses</h3><p>Companies facing succession, expansion, recapitalization, or ownership transition, with current interest in aesthetics, wellness, healthcare services, and other durable service categories.</p></article>
          <article class="card"><h3>Select real estate opportunities</h3><p>Properties, portfolios, and operating real estate where basis, repositioning potential, or ownership complexity creates a compelling investment thesis.</p></article>
          <article class="card"><h3>Operating partnerships</h3><p>Partnerships with experienced operators and sector specialists where resources and execution capability can accelerate growth or strategic improvement.</p></article>
        </div>
      </div>
    </section>

    <section id="process" class="dark-band">
      <div class="wrap">
        <div class="eyebrow">HOW OPPORTUNITIES ADVANCE</div>
        <h2>A disciplined path from origination to decision.</h2>
        <p class="lead section-intro">Every situation moves through a controlled investment process that separates market interest from actionable conviction.</p>
        <div class="process-line" aria-label="Clearline Capital opportunity process">
          <article class="process-step"><span>01</span><h3>Originate</h3><p>The firm develops potential situations through proprietary intelligence, sector research, trusted referrals, and operator insight.</p></article>
          <article class="process-step"><span>02</span><h3>Qualify</h3><p>Business or asset quality, ownership context, sector dynamics, strategic relevance, and seller objectives are tested against the mandate.</p></article>
          <article class="process-step"><span>03</span><h3>Underwrite</h3><p>Qualified situations advance through financial analysis, operating review, risk assessment, transaction design, and financing plans.</p></article>
          <article class="process-step"><span>04</span><h3>Validate</h3><p>Relevant advisors, operators, and specialists examine the thesis through professional diligence and scenario review.</p></article>
          <article class="process-step"><span>05</span><h3>Decide</h3><p>Clearline Capital proceeds only when the evidence, economics, and execution plan support investment conviction.</p></article>
        </div>
      </div>
    </section>

    <section id="network">
      <div class="wrap split">
        <div>
          <div class="eyebrow">NETWORK AND GOVERNANCE</div>
          <h2>Experienced perspective. Clear authority.</h2>
        </div>
        <div>
          <p class="lead">Clearline Capital operates through a private network of investors, founders, operators, advisors, and funding partners. The network contributes sector knowledge, operating experience, transaction perspective, and relevant resources to select situations.</p>
          <div class="rule"></div>
          <p class="body">Opportunities are evaluated through disciplined underwriting, professional diligence, and clearly defined investment governance.</p>
          <ul class="leadership-points">
            <li>Experienced investor and operator perspective.</li>
            <li>Independent professional diligence.</li>
            <li>Disciplined resource allocation.</li>
            <li>Defined investment governance.</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="intelligence" class="intelligence-field-section" aria-labelledby="intelligence-title">
      <div class="intelligence-field-shell">
        <div class="intelligence-field-header">
          <div>
            <div class="eyebrow">QUALIFICATION ARCHITECTURE</div>
            <h2 id="intelligence-title">Filtering market complexity into qualified situations.</h2>
          </div>
        </div>

        <div class="qualification-architecture" aria-label="Clearline qualification architecture">
          <div class="qualification-panels">
            <section class="qualification-panel market-panel" aria-labelledby="market-panel-title">
              <div class="qa-panel-heading">
                <span class="qa-icon market" aria-hidden="true"></span>
                <h3 id="market-panel-title">Market Universe</h3>
                <span class="qa-panel-kicker">Inputs</span>
              </div>
              <ul class="qa-market-list">
                <li><span class="market-line-icon" aria-hidden="true"></span><span>Businesses</span></li>
                <li><span class="market-line-icon" aria-hidden="true"></span><span>Assets</span></li>
                <li><span class="market-line-icon" aria-hidden="true"></span><span>Ownership Structures</span></li>
                <li><span class="market-line-icon" aria-hidden="true"></span><span>Operating Indicators</span></li>
                <li><span class="market-line-icon" aria-hidden="true"></span><span>Transaction Activity</span></li>
                <li><span class="market-line-icon" aria-hidden="true"></span><span>Relationship Context</span></li>
                <li><span class="market-line-icon" aria-hidden="true"></span><span>Risk Indicators</span></li>
              </ul>
            </section>

            <section class="qualification-panel lens-panel" aria-labelledby="lens-panel-title">
              <div class="qa-panel-heading">
                <span class="qa-icon lens" aria-hidden="true"></span>
                <h3 id="lens-panel-title">Intelligence Lenses</h3>
                <span class="qa-panel-kicker">Screening</span>
              </div>
              <ul class="qa-lens-list">
                <li>Origination Intelligence</li>
                <li>Market Mapping</li>
                <li>Ownership Research</li>
                <li>Diligence Coordination</li>
                <li>Risk and Scenario Analysis</li>
                <li>Institutional Memory</li>
              </ul>
            </section>

            <section class="qualification-panel output-panel" aria-labelledby="output-panel-title">
              <div class="qa-panel-heading">
                <span class="qa-icon output" aria-hidden="true"></span>
                <h3 id="output-panel-title">Qualified Situations</h3>
                <span class="qa-panel-kicker">Output</span>
              </div>
              <ul class="qa-output-list">
                <li><span class="output-diamond" aria-hidden="true"></span><span>Ownership context established</span></li>
                <li><span class="output-diamond" aria-hidden="true"></span><span>Path to engagement identified</span></li>
                <li><span class="output-diamond" aria-hidden="true"></span><span>Strategic and preliminary underwriting fit supported</span></li>
              </ul>
              <p class="qa-output-note">Only situations meeting all three conditions advance to deeper evaluation.</p>
            </section>
          </div>
          <div class="qa-connector left" aria-hidden="true"><span class="qa-connector-line l1"></span><span class="qa-connector-line l2"></span><span class="qa-connector-line l3"></span><span class="qa-node n1"></span><span class="qa-node n2"></span><span class="qa-node n3"></span></div>
          <div class="qa-connector right" aria-hidden="true"><span class="qa-connector-line l1"></span><span class="qa-connector-line l2"></span><span class="qa-connector-line l3"></span><span class="qa-node n1"></span><span class="qa-node n2"></span><span class="qa-node n3"></span></div>
        </div>
        <p class="governance-note">The platform expands visibility and accelerates analysis. Investment decisions and transaction authority remain with Clearline Capital’s investment professionals and operating partners.</p>
        <p class="intelligence-reduced-copy">The intelligence field combines broad private-market inputs with proprietary agentic analysis, resolves toward qualified situations, and transitions directly into Access.</p>
      </div>
    </section>

    <section id="access" class="access-section">
      <div class="wrap split">
        <div>
          <div class="eyebrow">ACCESS</div>
          <h2>The right introduction matters.</h2>
        </div>
        <div>
          <p class="lead">Clearline Capital considers acquisition opportunities, operating partnerships, and investor introductions submitted with credible context. Share the relevant parties, the basis for the introduction, and why the situation merits review.</p>
          <p class="body">Submissions are screened for mandate fit, source quality, and strategic relevance. Only qualified matters advance.</p>
          <form name="access-request" method="POST" action="/thank-you" data-netlify="true" netlify-honeypot="bot-field" class="form-shell">
            <input type="hidden" name="form-name" value="access-request" />
            <p class="hidden"><label>Do not fill this out: <input name="bot-field" /></label></p>
            <input class="field" name="name" placeholder="Name" aria-label="Name" required />
            <input class="field" name="email" type="email" placeholder="Email" aria-label="Email" required />
            <input class="field" name="company" placeholder="Company" aria-label="Company" />
            <input class="field" name="referred-by" placeholder="Referred by" aria-label="Referred by" required />
            <textarea name="context" placeholder="Brief context" aria-label="Brief context" required></textarea>
            <button class="submit" type="submit">Request Consideration</button>
          </form>
          <p class="small">Nothing on this page is an offer to sell securities or a solicitation to buy securities. Clearline Capital evaluates opportunities privately and selectively. Any investment, acquisition, partnership, or transaction activity is subject to independent review, diligence, documentation, professional advice, and final approval by the appropriate parties.</p>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="wrap">
      <span>Clearline Capital. Private investment and acquisition firm.</span>
      <span>Selective review. Direct access.</span>
    </div>
  </footer>

  <script>
    const nav = document.querySelector('.site-nav');
    function setNavState() { nav?.classList.toggle('is-scrolled', window.scrollY > 24); }
    setNavState();
    window.addEventListener('scroll', setNavState, { passive: true });

    const inviteInput = document.getElementById('invite-code');
    const inviteButton = document.getElementById('invite-submit');
    async function validateInvite() {
      const code = inviteInput?.value.trim();
      if (!code || !inviteButton) return;
      const originalText = inviteButton.textContent;
      inviteButton.textContent = 'Checking';
      inviteButton.disabled = true;
      try {
        const response = await fetch('/api/validate-code', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ code }) });
        const { valid, token } = await response.json();
        if (valid && token) { window.location.href = `/contact?token=${encodeURIComponent(token)}`; return; }
        inviteInput.value = '';
        inviteInput.placeholder = 'Code not recognized';
      } catch (error) {
        inviteInput.placeholder = 'Unable to validate';
      } finally {
        inviteButton.textContent = originalText;
        inviteButton.disabled = false;
      }
    }
    inviteButton?.addEventListener('click', validateInvite);
    inviteInput?.addEventListener('keydown', (event) => { if (event.key === 'Enter') validateInvite(); });

    const intelligenceSection = document.querySelector('.intelligence-field-section');
    if (intelligenceSection && 'IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) intelligenceSection.classList.add('is-visible');
        });
      }, { threshold: 0.22 });
      observer.observe(intelligenceSection);
    } else {
      intelligenceSection?.classList.add('is-visible');
    }
  </script>
</body>
</html>
