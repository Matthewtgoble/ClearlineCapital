<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Clearline Capital | Private Investment and Acquisition Firm</title>
  <meta name="description" content="Clearline Capital pursues off-market business acquisitions, select real estate opportunities, and operating partnerships through direct relationships, disciplined underwriting, and aligned capital." />
  <meta property="og:title" content="Clearline Capital" />
  <meta property="og:description" content="A private investment and acquisition firm pursuing off-market business acquisitions, select real estate opportunities, and operating partnerships." />
  <link rel="preload" as="image" href="/hero-clearline-1440.webp" imagesrcset="/hero-clearline-960.webp 960w, /hero-clearline-1440.webp 1440w, /hero-clearline-1920.webp 1920w" imagesizes="100vw" fetchpriority="high" />
  <style>

    :root {
      --black: #050505;
      --ink: #f7f2e8;
      --muted: rgba(247,242,232,.68);
      --soft: rgba(247,242,232,.42);
      --line: rgba(218,174,98,.28);
      --gold: #d6a85e;
      --gold2: #f0d6a0;
      --card: rgba(9,10,9,.72);
      --max: 1180px;
      --serif: Georgia, 'Times New Roman', serif;
      --sans: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { margin: 0; background: var(--black); color: var(--ink); font-family: var(--sans); letter-spacing: -.01em; overflow-x: hidden; }
    body:before { content: ''; position: fixed; inset: 0; pointer-events: none; z-index: 20; opacity: .10; background-image: radial-gradient(rgba(255,255,255,.45) .5px, transparent .5px); background-size: 3px 3px; mix-blend-mode: overlay; }
    a { color: inherit; text-decoration: none; }
    .site-nav { position: fixed; z-index: 30; top: 0; left: 0; right: 0; height: 104px; display: flex; align-items: center; justify-content: space-between; padding: 20px clamp(20px, 4vw, 54px); background: linear-gradient(to bottom, rgba(0,0,0,.70), rgba(0,0,0,0)); border-bottom: 1px solid transparent; transition: background .28s ease, border-color .28s ease; }
    .site-nav.is-scrolled { background: linear-gradient(to bottom, rgba(5,5,5,.96), rgba(5,5,5,.9)); border-bottom-color: rgba(247,242,232,.09); }
    .logo { display: flex; align-items: center; gap: 12px; min-width: 164px; }
    .logo img { width: 132px; height: auto; display: block; }
    .nav-links { display: flex; align-items: center; gap: clamp(10px, 1.15vw, 16px); font-size: 11px; text-transform: uppercase; letter-spacing: .16em; color: rgba(247,242,232,.72); }
    .nav-links a { transition: color .25s ease; white-space: nowrap; }
    .nav-links a:hover { color: var(--gold2); }
    .nav-cta { border: 1px solid var(--line); border-radius: 999px; padding: 11px 14px; color: var(--gold2) !important; background: rgba(214,168,94,.08); }
    .hero { min-height: 100vh; position: relative; display: grid; align-items: end; padding: clamp(132px, 15vh, 176px) clamp(22px, 5vw, 72px) clamp(24px, 4vh, 42px); overflow: hidden; }
    .hero-media { position: absolute; inset: 0; z-index: 0; }
    .hero-media:after { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, rgba(0,0,0,.86) 0%, rgba(0,0,0,.48) 44%, rgba(0,0,0,.20) 100%), linear-gradient(to top, rgba(0,0,0,.94) 0%, rgba(0,0,0,.20) 42%, rgba(0,0,0,.50) 100%); }
    .hero-media img { width: 100%; height: 100%; object-fit: cover; object-position: center; display: block; }
    .hero-inner { position: relative; z-index: 2; max-width: var(--max); width: 100%; margin: 0 auto; display: grid; grid-template-columns: minmax(0, 1.1fr) 390px; gap: 48px; align-items: end; }
    .hero-narrative { align-self: end; padding-top: clamp(56px, 11vh, 128px); }
    .eyebrow { color: var(--gold2); text-transform: uppercase; letter-spacing: .3em; font-size: clamp(13px, 1.05vw, 15px); margin-bottom: 18px; }
    h1, h2, h3 { font-family: var(--serif); font-weight: 400; margin: 0; text-wrap: pretty; }
    h1 { font-size: clamp(56px, 7vw, 104px); line-height: .9; max-width: 820px; letter-spacing: -.06em; }
    h1 span { display: block; }
    h2 { font-size: clamp(38px, 5vw, 74px); line-height: .98; letter-spacing: -.045em; }
    .hero-copy { max-width: 680px; margin-top: 24px; color: rgba(247,242,232,.82); font-size: clamp(15px, 1.35vw, 18px); line-height: 1.58; }
    .access-card { border: 1px solid rgba(214,168,94,.34); background: linear-gradient(145deg, rgba(7,8,8,.88), rgba(30,23,13,.72)); box-shadow: 0 30px 80px rgba(0,0,0,.5); border-radius: 2px; padding: 28px; position: relative; overflow: hidden; }
    .access-card:before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, var(--gold2), transparent); opacity: .8; }
    .access-title { font-size: 13px; text-transform: uppercase; letter-spacing: .24em; color: var(--gold2); margin-bottom: 18px; }
    .input-row { display: grid; grid-template-columns: 1fr auto; border: 1px solid rgba(247,242,232,.18); background: rgba(0,0,0,.35); }
    .input-row input { min-width: 0; padding: 15px 14px; background: transparent; border: 0; color: var(--ink); outline: none; text-transform: uppercase; letter-spacing: .14em; }
    .input-row button { background: rgba(214,168,94,.14); color: var(--gold2); border: 0; border-left: 1px solid rgba(247,242,232,.14); padding: 0 18px; text-transform: uppercase; letter-spacing: .18em; font-size: 11px; }
    .small { color: rgba(247,242,232,.55); font-size: 12px; line-height: 1.55; margin-top: 14px; }
    .secondary-link { display: inline-flex; margin-top: 22px; color: var(--ink); border-bottom: 1px solid var(--gold); padding-bottom: 6px; font-size: 13px; letter-spacing: .12em; text-transform: uppercase; }
    section { padding: 104px clamp(22px, 5vw, 72px); position: relative; scroll-margin-top: 128px; }
    #firm { padding-top: clamp(72px, 8vh, 96px); }
    .wrap { max-width: var(--max); margin: 0 auto; }
    .split { display: grid; grid-template-columns: .85fr 1.15fr; gap: clamp(34px, 7vw, 96px); align-items: start; }
    .lead { font-size: clamp(16px, 1.55vw, 21px); line-height: 1.58; color: rgba(247,242,232,.76); margin: 0; }
    .body { color: rgba(247,242,232,.64); font-size: 15px; line-height: 1.75; }
    .rule { height: 1px; background: linear-gradient(90deg, var(--gold), transparent); opacity: .45; margin: 32px 0; }
    .cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 48px; }
    .card { border: 1px solid rgba(247,242,232,.12); background: linear-gradient(145deg, rgba(255,255,255,.045), rgba(255,255,255,.015)); padding: 28px; min-height: 220px; position: relative; }
    .card:after { content: ''; position: absolute; inset: 0; border: 1px solid rgba(214,168,94,.08); transform: translate(5px, 5px); pointer-events: none; }
    .card h3 { font-size: 27px; line-height: 1.05; margin-bottom: 22px; }
    .card p { color: rgba(247,242,232,.62); line-height: 1.68; margin: 0 0 12px; }
    .section-intro { max-width: 900px; margin-top: 24px; }
    .process-line { position: relative; display: grid; grid-template-columns: repeat(5, 1fr); gap: 20px; margin-top: 54px; padding-top: 30px; }
    .process-line:before { content: ''; position: absolute; left: 0; right: 0; top: 10px; height: 1px; background: linear-gradient(90deg, rgba(214,168,94,.78), rgba(214,168,94,.16)); }
    .process-step { position: relative; padding-right: 18px; }
    .process-step:before { content: ''; position: absolute; top: -25px; left: 0; width: 9px; height: 9px; border-radius: 999px; background: var(--gold2); box-shadow: 0 0 0 6px rgba(214,168,94,.08); }
    .process-step span { display: block; color: var(--gold2); letter-spacing: .18em; font-size: 11px; margin-bottom: 18px; }
    .process-step h3 { font-size: 24px; line-height: 1.05; margin-bottom: 14px; }
    .process-step p { color: rgba(247,242,232,.62); line-height: 1.62; margin: 0; font-size: 14px; }
    .dark-band { background: radial-gradient(circle at 18% 12%, rgba(214,168,94,.16), transparent 32%), linear-gradient(180deg, #050505, #0b0907); }
    .leadership-points { list-style: none; padding: 0; margin: 38px 0 0; display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 18px 28px; }
    .leadership-points li { border-top: 1px solid rgba(214,168,94,.36); padding-top: 14px; color: rgba(247,242,232,.72); line-height: 1.55; }
    .intelligence-field-section {
      --field-progress: 0;
      --field-ink: #f7f2e8;
      --field-muted: rgba(247,242,232,.66);
      --field-soft: rgba(247,242,232,.42);
      --field-gold: #d6a85e;
      --field-gold2: #f0d6a0;
      --field-line: rgba(214,168,94,.32);
      --stage-one: clamp(0, calc((var(--field-progress) - .25) * 5), 1);
      --stage-two: clamp(0, calc((var(--field-progress) - .50) * 6), 1);
      --stage-three: clamp(0, calc((var(--field-progress) - .64) * 8.5), 1);
      --threshold-event: clamp(0, calc((var(--field-progress) - .64) * 20), 1);
      --stage-four: clamp(0, calc((var(--field-progress) - .82) * 6), 1);
      min-height: 220vh;
      padding: 0 clamp(22px, 5vw, 72px);
      background:
        radial-gradient(circle at 14% 18%, rgba(214,168,94,.12), transparent 30%),
        linear-gradient(180deg, #050505 0%, #080706 48%, #050505 100%);
      overflow: clip;
    }
    .intelligence-field-sticky {
      position: sticky;
      top: 0;
      min-height: 100vh;
      display: grid;
      align-items: center;
      padding: clamp(96px, 12vh, 132px) 0 clamp(54px, 7vh, 78px);
    }
    .intelligence-field-shell { max-width: min(1440px, 100%); margin: 0 auto; width: 100%; }
    .intelligence-field-header { max-width: 960px; margin-bottom: clamp(24px, 4vh, 44px); }
    .intelligence-field-header .eyebrow { margin-bottom: 14px; }
    .intelligence-field-header h2 { max-width: 920px; font-size: clamp(42px, 5.4vw, 82px); }
    .intelligence-field-header .lead { margin-top: 22px; max-width: 900px; }
    .intelligence-map { position: relative; min-height: clamp(650px, 62vh, 780px); }
    .field-copy { position: relative; z-index: 3; pointer-events: none; }
    .map-visual { position: absolute; inset: 0; width: 100%; height: 100%; overflow: visible; z-index: 1; }
    .map-visual * { vector-effect: non-scaling-stroke; }
    .field-grid { opacity: .34; }
    .field-contours { opacity: .72; }
    .market-point { opacity: calc(.38 + (1 - var(--stage-two)) * .34); transition: opacity .4s ease; }
    .market-point.irrelevant { opacity: calc(.26 * (1 - var(--stage-two))); }
    .relationship-trace, .risk-fracture, .qualified-path, .situation-marker, .memory-return { opacity: 0; transition: opacity .45s ease, stroke-dashoffset .7s ease, transform .55s ease; }
    .relationship-trace, .risk-fracture { opacity: var(--stage-one); }
    .qualified-path, .situation-marker { opacity: var(--stage-two); }
    .memory-return { opacity: var(--stage-four); }
    .field-labels, .capability-labels, .situation-profiles, .human-threshold, .human-decision, .memory-label { position: absolute; inset: 0; z-index: 2; }
    .field-label, .capability-label { position: absolute; color: var(--field-muted); font-size: 12px; line-height: 1.2; letter-spacing: .08em; text-transform: uppercase; }
    .field-label.emphasis, .capability-label.emphasis { color: var(--field-gold2); }
    .capability-label { opacity: var(--stage-one); color: rgba(247,242,232,.78); font-weight: 600; }
    .capability-label:before { content: ''; display: inline-block; width: 16px; height: 1px; margin: 0 8px 4px 0; background: var(--field-gold); opacity: .72; }
    .situation-profile { position: absolute; width: min(21vw, 248px); opacity: var(--stage-two); transform: translateY(calc((1 - var(--stage-two)) * 12px)); transition: opacity .45s ease, transform .45s ease; }
    .situation-profile h3 { font-size: clamp(19px, 1.6vw, 25px); line-height: 1.04; color: var(--field-ink); margin-bottom: 12px; }
    .situation-profile p { margin: 0 0 6px; color: var(--field-muted); font-size: 13px; line-height: 1.35; }
    .human-threshold { display: flex; align-items: flex-end; pointer-events: none; }
    .threshold-inner {
      width: 100%;
      min-height: clamp(128px, 17vh, 174px);
      margin-bottom: clamp(190px, 24vh, 250px);
      background: linear-gradient(180deg, rgba(8,7,6,.98), rgba(17,14,10,.98));
      border-top: 2px solid rgba(240,214,160,.84);
      border-bottom: 2px solid rgba(240,214,160,.84);
      box-shadow: 0 -26px 80px rgba(0,0,0,.42), 0 22px 70px rgba(0,0,0,.5);
      display: grid;
      grid-template-columns: minmax(300px, .95fr) minmax(320px, 1fr);
      gap: clamp(28px, 6vw, 94px);
      align-items: center;
      padding: clamp(28px, 4vw, 48px) clamp(28px, 5vw, 76px);
      opacity: var(--threshold-event);
      transform: translateY(calc((1 - var(--stage-three)) * 24px));
      transition: opacity .5s ease, transform .5s ease;
    }
    .threshold-inner h3 { font-size: clamp(32px, 4.5vw, 64px); line-height: .92; letter-spacing: -.04em; text-transform: uppercase; }
    .threshold-inner p { margin: 0; color: var(--field-gold2); font-size: clamp(17px, 2vw, 28px); line-height: 1.28; font-weight: 600; }
    .human-decision { display: flex; align-items: flex-end; pointer-events: none; }
    .decision-inner { width: 100%; padding: 0 clamp(28px, 5vw, 76px); opacity: var(--stage-four); transform: translateY(calc((1 - var(--stage-four)) * 18px)); transition: opacity .5s ease, transform .5s ease; }
    .decision-inner h3 { font-size: clamp(34px, 4.2vw, 68px); line-height: .96; margin-bottom: clamp(22px, 3vw, 38px); }
    .decision-responsibilities { display: grid; grid-template-columns: repeat(6, minmax(0, 1fr)); gap: clamp(18px, 2.3vw, 36px); list-style: none; padding: 0; margin: 0; }
    .decision-responsibilities li { color: var(--field-ink); font-weight: 600; font-size: clamp(13px, 1.15vw, 17px); line-height: 1.25; }
    .decision-responsibilities li:before { content: ''; display: block; width: 72px; height: 1px; background: var(--field-gold); margin-bottom: 13px; opacity: .7; }
    .memory-label { pointer-events: none; }
    .memory-label div { position: absolute; right: 7%; bottom: 6%; opacity: var(--stage-four); color: var(--field-muted); font-size: 13px; line-height: 1.35; }
    .memory-label strong { display: block; color: var(--field-gold2); margin-bottom: 4px; letter-spacing: .08em; text-transform: uppercase; }
    .mobile-field-copy { display: none; }
    .intelligence-reduced-copy { position: absolute; left: -9999px; }
    @media (max-width: 980px) {
      .intelligence-field-section { min-height: auto; padding: 84px 20px 72px; }
      .intelligence-field-sticky { position: relative; min-height: auto; padding: 0; }
      .intelligence-field-header h2 { font-size: clamp(38px, 10vw, 72px); }
      .intelligence-map { min-height: auto; padding-bottom: 24px; }
      .map-visual.desktop-map, .field-labels, .capability-labels, .situation-profiles { display: none; }
      .map-visual.mobile-map { display: block; position: absolute; inset: 150px 0 auto 0; height: 620px; opacity: .9; }
      .mobile-field-copy { display: block; position: relative; z-index: 3; }
      .mobile-field-step { margin: 0 0 26px; max-width: 330px; }
      .mobile-field-step:nth-child(2) { margin-left: auto; }
      .mobile-field-step h3 { font-size: 21px; line-height: 1.08; margin-bottom: 9px; }
      .mobile-field-step p { margin: 0; color: var(--field-muted); font-size: 13px; line-height: 1.48; }
      .human-threshold, .human-decision, .memory-label { position: relative; inset: auto; z-index: 4; display: block; opacity: 1 !important; }
      .human-threshold::before { display: none; }
      .threshold-inner { min-height: 148px; margin: 28px 0 30px; grid-template-columns: 1fr; gap: 12px; padding: 26px 22px; opacity: 1 !important; transform: none !important; }
      .threshold-inner h3 { font-size: clamp(30px, 8.5vw, 43px); }
      .threshold-inner p { font-size: clamp(14px, 4vw, 18px); line-height: 1.34; }
      .decision-inner { padding: 0 4px; opacity: 1 !important; transform: none !important; }
      .decision-inner h3 { font-size: clamp(32px, 9vw, 48px); max-width: 330px; }
      .decision-responsibilities { grid-template-columns: 1fr 1fr; gap: 18px 22px; }
      .memory-label div { position: static; margin-top: 26px; opacity: 1 !important; }
      .memory-label div { right: auto; left: 28px; bottom: 0; font-size: 12px; max-width: 300px; }
    }
    @media (min-width: 981px) { .map-visual.mobile-map { display: none; } }
    @media (max-width: 430px) {
      .intelligence-map { min-height: auto; }
      .mobile-field-step { max-width: 300px; }
      .threshold-inner { margin: 28px 0 30px; }
      .decision-responsibilities { gap: 16px; }
    }
    @media (prefers-reduced-motion: reduce) {
      .intelligence-field-section { --field-progress: 1 !important; min-height: auto; }
      .intelligence-field-sticky { position: relative; min-height: auto; }
      .relationship-trace, .risk-fracture, .qualified-path, .situation-marker, .memory-return, .threshold-inner, .decision-inner, .situation-profile, .capability-label { transition: none !important; transform: none !important; }
    }

    .intelligence-field-header, .field-labels, .capability-labels, .situation-profiles { opacity: calc(1 - var(--threshold-event)); transition: opacity .2s ease; }
    .human-threshold { z-index: 6; }
    .human-threshold::before {
      content: '';
      position: absolute;
      left: -2%;
      right: -2%;
      bottom: clamp(70px, 9vh, 118px);
      height: clamp(300px, 40vh, 430px);
      background: linear-gradient(180deg, rgba(5,5,5,0), rgba(5,5,5,.98) 16%, rgba(8,7,6,1) 42%, rgba(8,7,6,1) 66%, rgba(5,5,5,.90) 86%, rgba(5,5,5,0));
      opacity: var(--threshold-event);
      pointer-events: none;
    }
    .threshold-inner { position: relative; z-index: 2; transform: none !important; background: linear-gradient(180deg, #080706, #12100c); }
    @media (prefers-reduced-motion: reduce) {
      .intelligence-field-header { opacity: 1; }
      .human-threshold::before { opacity: 1; }
    }

    .access-section { background: linear-gradient(180deg, #050505, #090705); }
    .hidden { display: none; }
    .form-shell { margin-top: 36px; display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .field, textarea { border: 1px solid rgba(247,242,232,.13); background: rgba(247,242,232,.035); padding: 15px 14px; color: var(--ink); min-height: 52px; font: inherit; outline: none; }
    textarea { grid-column: 1 / -1; min-height: 122px; resize: vertical; }
    .submit { grid-column: 1 / -1; justify-self: start; border: 1px solid rgba(214,168,94,.42); background: rgba(214,168,94,.12); color: var(--gold2); padding: 14px 22px; text-transform: uppercase; letter-spacing: .18em; font-size: 12px; }
    footer { padding: 48px clamp(22px, 5vw, 72px); border-top: 1px solid rgba(247,242,232,.1); color: rgba(247,242,232,.62); }
    footer .wrap { display: flex; justify-content: space-between; gap: 20px; font-size: 12px; letter-spacing: .08em; text-transform: uppercase; }
    @media (max-width: 1180px) { .nav-links { gap: 10px; font-size: 10px; letter-spacing: .12em; } .logo { min-width: 132px; } }
    @media (max-width: 980px) {
      .hero-inner, .split { grid-template-columns: 1fr; }
      .hero-narrative { padding-top: 0; }
      .access-card { max-width: 480px; }
      .cards, .leadership-points { grid-template-columns: 1fr; }
      .process-line { grid-template-columns: 1fr; gap: 0; margin-top: 42px; padding: 0 0 0 24px; }
      .process-line:before { left: 4px; right: auto; top: 2px; bottom: 6px; width: 1px; height: auto; background: linear-gradient(180deg, rgba(214,168,94,.78), rgba(214,168,94,.16)); }
      .process-step { padding: 0 0 28px; }
      .process-step:before { top: 3px; left: -24px; width: 8px; height: 8px; }
      .process-step span { margin-bottom: 8px; }
      .process-step h3 { font-size: 22px; margin-bottom: 8px; }
      .process-step p { font-size: 13px; line-height: 1.55; max-width: 620px; }
      .nav-links { display: none; }
    }
    @media (max-width: 620px) {
      .site-nav { position: sticky; height: 72px; padding: 8px 18px 7px; background: linear-gradient(to bottom, rgba(0,0,0,.96), rgba(0,0,0,.86)); border-bottom: 1px solid rgba(247,242,232,.08); }
      .logo img { width: 98px; }
      .hero { min-height: calc(100svh - 72px); padding: 42px 20px 32px; }
      section { padding: 72px 20px; scroll-margin-top: 96px; }
      .form-shell { grid-template-columns: 1fr; }
      textarea, .submit { grid-column: auto; }
      h1 { font-size: 54px; }
      footer .wrap { flex-direction: column; }
    }
    @media (prefers-reduced-motion: reduce) {
      * { animation: none !important; scroll-behavior: auto !important; }
    }

  </style>
</head>
<body>
  <nav class="site-nav" aria-label="Primary navigation">
    <a class="logo" href="#top" aria-label="Clearline Capital home"><img src="/logo-white-132.webp" srcset="/logo-white-132.webp 132w, /logo-white-264.webp 264w" sizes="132px" width="132" height="83" alt="Clearline Capital" /></a>
    <div class="nav-links">
      <a href="#firm">Firm</a>
      <a href="#focus">Investment Focus</a>
      <a href="#process">Process</a>
      <a href="#leadership">Leadership and Network</a>
      <a href="#intelligence">Intelligence</a>
      <a href="#access" class="nav-cta">Request Consideration</a>
    </div>
  </nav>

  <main id="top">
    <header class="hero">
      <picture class="hero-media" aria-hidden="true">
        <source type="image/avif" srcset="/hero-clearline-960.avif 960w, /hero-clearline-1440.avif 1440w, /hero-clearline-1920.avif 1920w" sizes="100vw" />
        <source type="image/webp" srcset="/hero-clearline-960.webp 960w, /hero-clearline-1440.webp 1440w, /hero-clearline-1920.webp 1920w" sizes="100vw" />
        <img src="/hero-clearline-1440.webp" srcset="/hero-clearline-960.webp 960w, /hero-clearline-1440.webp 1440w, /hero-clearline-1920.webp 1920w" sizes="100vw" width="1440" height="810" alt="" fetchpriority="high" decoding="sync" />
      </picture>
      <div class="hero-inner">
        <div class="hero-narrative">
          <div class="eyebrow">PRIVATE INVESTMENT AND ACQUISITION FIRM</div>
          <h1>The most compelling opportunities begin with a private conversation.</h1>
