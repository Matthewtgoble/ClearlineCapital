  <script>
    const nav = document.querySelector('.site-nav');
    function setNavState() { nav?.classList.toggle('is-scrolled', window.scrollY > 24); }
    setNavState();
    window.addEventListener('scroll', setNavState, { passive: true });

    const inviteInput = document.getElementById('invite-code');
    const inviteButton = document.getElementById('invite-submit');
    async function validateInvite() {
      const code = inviteInput?.value.trim();
      if (!code || !inviteButton) return;
      const originalText = inviteButton.textContent;
      inviteButton.textContent = 'Checking';
      inviteButton.disabled = true;
      try {
        const response = await fetch('/api/validate-code', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ code }) });
        const { valid, token } = await response.json();
        if (valid && token) { window.location.href = `/contact?token=${encodeURIComponent(token)}`; return; }
        inviteInput.value = '';
        inviteInput.placeholder = 'Code not recognized';
      } catch (error) {
        inviteInput.placeholder = 'Unable to validate';
      } finally {
        inviteButton.textContent = originalText;
        inviteButton.disabled = false;
      }
    }
    inviteButton?.addEventListener('click', validateInvite);
    inviteInput?.addEventListener('keydown', (event) => { if (event.key === 'Enter') validateInvite(); });

    const intelligenceSection = document.querySelector('.intelligence-field-section');
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    function clamp(value, min, max) { return Math.min(max, Math.max(min, value)); }
    function updateIntelligenceProgress() {
      if (!intelligenceSection) return;
      if (reducedMotion.matches) {
        intelligenceSection.style.setProperty('--field-progress', '1');
        intelligenceSection.dataset.stage = 'resolved';
        return;
      }
      const rect = intelligenceSection.getBoundingClientRect();
      const travel = Math.max(1, rect.height - window.innerHeight);
      const progress = clamp(-rect.top / travel, 0, 1);
      intelligenceSection.style.setProperty('--field-progress', progress.toFixed(3));
      const stage = progress < .25 ? 'field' : progress < .5 ? 'resolution' : progress < .7 ? 'qualified' : progress < .82 ? 'authority' : 'decision';
      intelligenceSection.dataset.stage = stage;
    }
    updateIntelligenceProgress();
    window.addEventListener('scroll', updateIntelligenceProgress, { passive: true });
    window.addEventListener('resize', updateIntelligenceProgress);
    reducedMotion.addEventListener?.('change', updateIntelligenceProgress);
  </script>
