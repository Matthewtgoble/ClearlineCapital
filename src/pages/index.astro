---
const year = new Date().getFullYear();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Clearline Capital</title>
    <meta name="description" content="Clearline Capital — Private capital with clarity of vision and precision of execution." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>

    <!-- ── Header ── -->
    <header>
      <div class="header-inner">
        <a href="/" class="logo" aria-label="Clearline Capital home">
          <img src="/logo.png" alt="Clearline Capital" class="logo-img" />
        </a>
      </div>
    </header>

    <!-- ── Hero ── -->
    <section class="hero" aria-label="Hero">
      <div class="hero-overlay"></div>
      <div class="hero-scroll-fade"></div>
      <div class="hero-content">
        <h1>Invite-only Private Investment Enterprise</h1>
        <div class="invite-wrap">
          <div class="invite-divider"></div>
          <div class="invite-row">
            <input type="text" class="invite-input" placeholder="enter your invite code" />
            <button class="invite-arrow" aria-label="Submit">→</button>
          </div>
          <p class="invite-error" aria-live="polite">
            <span class="invite-error-icon">✕</span> the code you entered isn't valid, try again
          </p>
          <label class="invite-confirm" id="invite-confirm-label">
            <input type="checkbox" id="invite-checkbox" />
            <span>I understand my invite code is single-use. Leaving or refreshing this page will permanently invalidate it.</span>
          </label>
        </div>
      </div>
    </section>

    <!-- ── Contact ── -->
    <section class="contact" id="contact">
      <div class="contact-inner">

        <div class="contact-heading">
          <p class="eyebrow">Connect</p>
          <h2>You're in the right room</h2>
          <p class="contact-sub">
            Let's get acquainted, and please, you go first.
          </p>
        </div>

        <form
          name="contact"
          method="POST"
          action="/thank-you"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="contact-form"
          novalidate
        >
          <!-- Netlify hidden fields -->
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden"><label>Do not fill this out: <input name="bot-field" /></label></p>

          <!-- Required fields -->
          <div class="field">
            <input
              type="text"
              id="full-name"
              name="full-name"
              required
              autocomplete="name"
              placeholder=" "
            />
            <label for="full-name">Full Name</label>
          </div>

          <div class="field">
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              autocomplete="tel"
              placeholder=" "
            />
            <label for="phone">Phone Number</label>
          </div>

          <div class="field">
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              placeholder=" "
            />
            <label for="email">Email Address</label>
          </div>

          <div class="field">
            <input
              type="text"
              id="referred-by"
              name="referred-by"
              required
              placeholder=" "
            />
            <label for="referred-by">Referred By</label>
          </div>

          <!-- Optional fields -->
          <div class="field">
            <input
              type="url"
              id="linkedin"
              name="linkedin"
              autocomplete="url"
              placeholder=" "
            />
            <label for="linkedin">LinkedIn Profile <span class="opt">— optional</span></label>
          </div>

          <div class="field">
            <input
              type="text"
              id="instagram"
              name="instagram"
              autocomplete="off"
              placeholder=" "
            />
            <label for="instagram">Instagram Handle <span class="opt">— optional</span></label>
          </div>

          <div class="field">
            <input
              type="text"
              id="x-handle"
              name="x-handle"
              autocomplete="off"
              placeholder=" "
            />
            <label for="x-handle">X Handle <span class="opt">— optional</span></label>
          </div>

          <button type="submit" class="submit-btn">Submit</button>
        </form>

      </div>
    </section>

    <!-- ── Footer ── -->
    <footer>
      <p>&copy; {year} Clearline Capital. All rights reserved.</p>
    </footer>

  </body>

  <script>
    // ── Invite code gate ──
    const inviteWrap  = document.querySelector('.invite-wrap');
    const inviteInput = document.querySelector('.invite-input');
    const inviteArrow = document.querySelector('.invite-arrow');

    // Lock scroll on load
    document.body.style.overflow = 'hidden';
    document.documentElement.style.overflow = 'hidden';

    async function submitCode() {
      const code = inviteInput.value.trim();
      if (!code) return;

      const res  = await fetch('/api/validate-code', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ code }),
      });
      const { valid } = await res.json();

      if (valid) {
        inviteWrap.classList.remove('error');
        document.body.style.overflow = '';
        document.documentElement.style.overflow = '';
        document.querySelector('#contact').scrollIntoView({ behavior: 'smooth' });
      } else {
        inviteWrap.classList.add('error');
        inviteInput.value = '';
        inviteInput.focus();
      }
    }

    const inviteCheckbox = document.getElementById('invite-checkbox');
    const inviteConfirm  = document.getElementById('invite-confirm-label');

    // Disable arrow until checkbox is checked
    inviteArrow.disabled = true;

    // Show checkbox when user starts typing
    inviteInput.addEventListener('input', () => {
      if (inviteInput.value.trim().length > 0) {
        inviteConfirm.classList.add('visible');
      } else {
        inviteConfirm.classList.remove('visible');
        inviteCheckbox.checked = false;
        inviteArrow.disabled = true;
      }
    });

    // Enable arrow when checkbox is checked
    inviteCheckbox.addEventListener('change', () => {
      inviteArrow.disabled = !inviteCheckbox.checked;
    });

    inviteArrow.addEventListener('click', submitCode);
    inviteInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !inviteArrow.disabled) submitCode();
      if (inviteWrap.classList.contains('error')) {
        inviteWrap.classList.remove('error');
      }
    });

    // ── Scroll / parallax ──
    const header = document.querySelector('header');
    const hero = document.querySelector('.hero');
    const heroFade = document.querySelector('.hero-scroll-fade');
    let ticking = false;

    function updateHeader() {
      const y = window.scrollY;
      const heroHeight = hero.offsetHeight;
      const threshold = heroHeight * 0.5;
      const headerHeight = header.offsetHeight;

      // Parallax: hero background moves at 40% of scroll speed, creating depth
      hero.style.backgroundPositionY = `${y * 0.4}px`;

      // Scroll fade: starts only when scrolling begins, reaches full black by 75% of hero height
      const fadeEnd = heroHeight * 0.75;
      const fadeProgress = Math.max(0, Math.min(y / fadeEnd, 1));
      heroFade.style.opacity = String(fadeProgress);

      if (y <= threshold) {
        // Parallax zone: scroll position directly drives position & opacity
        const progress = y / threshold;
        header.style.transform = `translateY(${-progress * headerHeight}px)`;
        header.style.opacity = String(1 - progress);
        header.style.pointerEvents = progress >= 1 ? 'none' : '';
      } else {
        // Fully hidden past threshold
        header.style.transform = `translateY(-${headerHeight}px)`;
        header.style.opacity = '0';
        header.style.pointerEvents = 'none';
      }

      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(updateHeader);
        ticking = true;
      }
    }, { passive: true });
  </script>
</html>

<style>
  /* ─── Reset ─── */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* ─── Tokens ─── */
  :root {
    --gold:        #c9a96e;
    --gold-dim:    rgba(201, 169, 110, 0.45);
    --dark:        #0c0c0c;
    --dark-glass:  rgba(10, 10, 10, 0.82);
    --off-white:   #fafaf8;
    --muted:       #4a4845;
    --serif:       'Cormorant Garamond', Georgia, serif;
    --sans:        'Inter', system-ui, sans-serif;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--sans);
    background: var(--off-white);
    color: var(--dark);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ─── Header ─── */
  header {
    position: fixed;
    inset-block-start: 0;
    inset-inline: 0;
    z-index: 200;
    background: transparent;
    will-change: transform, opacity;
  }

  .header-inner {
    padding-inline: 24px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo {
    display: flex;
    flex-direction: column;
    gap: 3px;
    text-decoration: none;
    line-height: 1;
  }

  .logo-img {
    height: 64px;
    width: auto;
    display: block;
    margin-top: 1rem;
  }

  .header-cta {
    font-family: var(--sans);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--dark);
    background: transparent;
    border: 1px solid var(--dark);
    padding: 0.55rem 1.5rem;
    transition: background 0.22s ease, color 0.22s ease, border-color 0.22s ease;
  }

  .header-cta:hover,
  .header-cta:active {
    background: var(--gold);
    color: var(--dark);
    border-color: var(--gold);
  }

  /* ─── Hero ─── */
  .hero {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 560px;
    background-image: url('/hero.png');
    background-size: cover;
    background-position: center top;
    background-color: #111;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .hero-scroll-fade {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    height: 100%;
    background: linear-gradient(to top, #000 0%, #000 35%, rgba(0,0,0,0.7) 55%, transparent 85%);
    opacity: 0;
    pointer-events: none;
    z-index: 1;
  }

  /* Subtle radial gold glow + permanent black anchor at the bottom */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 55% at 50% 48%, rgba(201, 169, 110, 0.07) 0%, transparent 70%),
      linear-gradient(180deg, transparent 55%, rgba(0, 0, 0, 0.6) 80%, #000 100%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-inline: 1.5rem;
    max-width: 820px;
  }

  .eyebrow {
    font-family: var(--sans);
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.5rem;
  }

  .hero-content h1 {
    font-family: var(--serif);
    font-size: clamp(2.6rem, 6vw, 4.8rem);
    font-weight: 300;
    line-height: 1.18;
    color: #fff;
    margin-bottom: 2.5rem;
  }

  .invite-wrap {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    margin-inline: auto;
    gap: 0;
  }

  .invite-divider {
    width: 100%;
    height: 1px;
    background: rgba(255, 255, 255, 0.25);
    margin-bottom: 0;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .invite-row {
    display: flex;
    align-items: center;
    position: relative;
    width: 100%;
  }

  .invite-error {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--sans);
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: #e05555;
    margin-top: 0.65rem;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .invite-error-icon {
    font-size: 0.6rem;
  }

  .invite-wrap.error .invite-divider,
  .invite-wrap.error .invite-error {
    opacity: 1;
  }

  .invite-confirm {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    margin-top: 1.25rem;
    max-width: 320px;
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .invite-confirm.visible {
    opacity: 1;
    pointer-events: all;
  }

  .invite-confirm input[type="checkbox"] {
    margin-top: 2px;
    accent-color: var(--gold);
    flex-shrink: 0;
    cursor: pointer;
  }

  .invite-confirm span {
    font-family: var(--sans);
    font-size: 0.62rem;
    font-weight: 300;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.6;
    text-align: left;
  }

  .invite-arrow:disabled {
    opacity: 0.25;
    cursor: not-allowed;
  }

  .invite-input {
    width: 320px;
    max-width: 80vw;
    background: rgba(0, 0, 0, 0.5);
    border: none;
    outline: none;
    font-family: var(--sans);
    font-size: 0.72rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    padding: 0.85rem 2.5rem 0.85rem 1.25rem;
    text-align: center;
    transition: background 0.25s ease;
  }

  .invite-input::placeholder {
    color: var(--gold);
    opacity: 1;
  }

  .invite-input:focus {
    background: rgba(0, 0, 0, 0.65);
  }

  .invite-arrow {
    position: absolute;
    right: 0.75rem;
    background: none;
    border: none;
    color: var(--gold);
    font-size: 1.1rem;
    cursor: pointer;
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.25s ease, transform 0.25s ease;
    padding: 0;
    line-height: 1;
  }

  .invite-wrap:focus-within .invite-arrow,
  .invite-input:not(:placeholder-shown) ~ .invite-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .invite-arrow:hover {
    color: #fff;
  }

  /* ─── Contact Section ─── */
  .contact {
    padding-block: 9rem;
    padding-inline: 2rem;
    background: #000;
  }

  .contact-inner {
    max-width: 600px;
    margin-inline: auto;
  }

  .contact-heading {
    text-align: center;
    margin-bottom: 4.5rem;
  }

  .contact-heading .eyebrow {
    color: var(--gold);
    margin-bottom: 1.1rem;
  }

  .contact-heading h2 {
    font-family: var(--serif);
    font-size: clamp(1.9rem, 4vw, 2.9rem);
    font-weight: 300;
    color: #d4d0cb;
    margin-bottom: 1rem;
  }

  .contact-sub {
    font-size: 0.875rem;
    color: #9e9a95;
    line-height: 1.8;
  }

  /* ─── Form ─── */
  .hidden {
    display: none;
  }

  .contact-form {
    display: grid;
    gap: 3rem;
  }

  /* Each input + floating label */
  .field {
    position: relative;
    /* gold underline sweep */
  }

  .field::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0%;
    height: 1px;
    background: var(--gold);
    transition: width 0.38s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }

  .field:focus-within::after {
    width: 100%;
  }

  .field input {
    display: block;
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(255,255,255,0.15);
    outline: none;
    font-family: var(--sans);
    font-size: 0.95rem;
    font-weight: 300;
    color: #d4d0cb;
    padding-block: 0.5rem 0.65rem;
    transition: border-color 0.3s ease;
    -webkit-text-fill-color: #d4d0cb;
  }

  /* Hide the static bottom border when focused (replaced by ::after sweep) */
  .field:focus-within input {
    border-bottom-color: transparent;
  }

  .field input:-webkit-autofill,
  .field input:-webkit-autofill:focus {
    -webkit-box-shadow: 0 0 0 1000px #000 inset;
    -webkit-text-fill-color: #d4d0cb;
  }

  /* Floating label */
  .field label {
    position: absolute;
    top: 0.5rem;
    left: 0;
    font-family: var(--sans);
    font-size: 0.82rem;
    font-weight: 400;
    letter-spacing: 0.03em;
    color: #9e9a95;
    pointer-events: none;
    transform-origin: left top;
    transition:
      transform 0.26s cubic-bezier(0.4, 0, 0.2, 1),
      color 0.26s ease,
      font-size 0.26s ease;
  }

  /* Float up when focused OR when input has a value (placeholder=" " trick) */
  .field input:focus ~ label,
  .field input:not(:placeholder-shown) ~ label {
    transform: translateY(-1.5rem) scale(0.75);
    color: var(--gold);
    letter-spacing: 0.08em;
  }

  .opt {
    font-family: var(--sans);
    font-size: 0.7em;
    font-style: italic;
    color: #9e9a95;
    font-weight: 300;
  }

  /* Submit button */
  .submit-btn {
    margin-top: 0.5rem;
    width: 100%;
    background: transparent;
    border: 1px solid var(--gold);
    color: var(--gold);
    font-family: var(--sans);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    padding-block: 1.1rem;
    cursor: pointer;
    transition: background 0.24s ease, color 0.24s ease, border-color 0.24s ease;
  }

  .submit-btn:hover,
  .submit-btn:active {
    background: var(--dark);
    border-color: var(--dark);
    color: var(--gold);
  }

  /* ─── Footer ─── */
  footer {
    background: #000;
    text-align: center;
    padding-block: 2rem;
  }

  footer p {
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    color: var(--gold);
  }

  /* ─── Responsive ─── */
  @media (max-width: 580px) {
    .header-inner {
      padding-inline: 1.25rem;
    }

    .header-cta {
      font-size: 0.65rem;
      padding: 0.5rem 1rem;
    }

    .hero-content h1 {
      font-size: 2.4rem;
    }

    .contact {
      padding-block: 5.5rem;
      padding-inline: 1.5rem;
    }

    .contact-form {
      gap: 2.5rem;
    }
  }
</style>
