---
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Clearline Capital | Private Capital, Trusted Access</title>
  <style>
    :root {
      --black: #050505;
      --ink: #f7f2e8;
      --muted: rgba(247,242,232,.68);
      --soft: rgba(247,242,232,.42);
      --line: rgba(218,174,98,.28);
      --gold: #d6a85e;
      --gold2: #f0d6a0;
      --card: rgba(9,10,9,.72);
      --card2: rgba(20,18,14,.62);
      --sand: #cbb78d;
      --danger: #b6894f;
      --max: 1180px;
      --serif: Georgia, 'Times New Roman', serif;
      --sans: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      background: var(--black);
      color: var(--ink);
      font-family: var(--sans);
      letter-spacing: -.01em;
      overflow-x: hidden;
    }
    body:before {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 20;
      opacity: .14;
      background-image: radial-gradient(rgba(255,255,255,.45) .5px, transparent .5px);
      background-size: 3px 3px;
      mix-blend-mode: overlay;
    }
    a { color: inherit; text-decoration: none; }
    .site-nav {
      position: fixed;
      z-index: 30;
      top: 0;
      left: 0;
      right: 0;
      height: 104px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px clamp(20px, 4vw, 54px);
      background: linear-gradient(to bottom, rgba(0,0,0,.72), rgba(0,0,0,0));
      backdrop-filter: blur(2px);
    }
    .logo {
      display: flex;
      align-items: center;
      gap: 12px;
      min-width: 180px;
    }
    .logo img { width: 132px; height: auto; display: block; }
    .nav-links { display: flex; align-items: center; gap: 22px; font-size: 12px; text-transform: uppercase; letter-spacing: .18em; color: rgba(247,242,232,.7); }
    .nav-links a { transition: color .25s ease; }
    .nav-links a:hover { color: var(--gold2); }
    .nav-cta { border: 1px solid var(--line); border-radius: 999px; padding: 11px 16px; color: var(--gold2) !important; background: rgba(214,168,94,.08); }
    .hero {
      min-height: 100vh;
      position: relative;
      display: grid;
      align-items: end;
      padding: 140px clamp(22px, 5vw, 72px) 56px;
      overflow: hidden;
    }
    .hero:before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: linear-gradient(90deg, rgba(0,0,0,.84) 0%, rgba(0,0,0,.44) 44%, rgba(0,0,0,.22) 100%), linear-gradient(to top, rgba(0,0,0,.94) 0%, rgba(0,0,0,.18) 42%, rgba(0,0,0,.5) 100%), url('data:image/jpeg;base64,');
      background-size: cover;
      background-position: center;
      transform: scale(1.025);
      animation: breathe 12s ease-in-out infinite alternate;
    }
    @keyframes breathe { from { transform: scale(1.025); } to { transform: scale(1.065); } }
    .hero-inner { position: relative; z-index: 2; max-width: var(--max); width: 100%; margin: 0 auto; display: grid; grid-template-columns: minmax(0, 1.1fr) 390px; gap: 48px; align-items: end; }
    .eyebrow { color: var(--gold2); text-transform: uppercase; letter-spacing: .28em; font-size: 12px; margin-bottom: 18px; }
    h1, h2, h3 { font-family: var(--serif); font-weight: 400; margin: 0; text-wrap: pretty; }
    h1 { font-size: clamp(56px, 8vw, 112px); line-height: .88; max-width: 780px; letter-spacing: -.06em; }
    .hero-copy { max-width: 630px; margin-top: 28px; color: rgba(247,242,232,.78); font-size: clamp(17px, 1.7vw, 22px); line-height: 1.55; }
    .access-card {
      border: 1px solid rgba(214,168,94,.34);
      background: linear-gradient(145deg, rgba(7,8,8,.88), rgba(30,23,13,.72));
      box-shadow: 0 30px 80px rgba(0,0,0,.5);
      border-radius: 2px;
      padding: 28px;
      position: relative;
      overflow: hidden;
    }
    .access-card:before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, var(--gold2), transparent); opacity: .8; }
    .access-title { font-size: 13px; text-transform: uppercase; letter-spacing: .24em; color: var(--gold2); margin-bottom: 18px; }
    .input-row { display: grid; grid-template-columns: 1fr auto; border: 1px solid rgba(247,242,232,.18); background: rgba(0,0,0,.35); }
    .input-row input { min-width: 0; padding: 15px 14px; background: transparent; border: 0; color: var(--ink); outline: none; text-transform: uppercase; letter-spacing: .14em; }
    .input-row button { background: rgba(214,168,94,.14); color: var(--gold2); border: 0; border-left: 1px solid rgba(247,242,232,.14); padding: 0 18px; text-transform: uppercase; letter-spacing: .18em; font-size: 11px; }
    .small { color: rgba(247,242,232,.55); font-size: 12px; line-height: 1.55; margin-top: 14px; }
    .secondary-link { display: inline-flex; margin-top: 22px; color: var(--ink); border-bottom: 1px solid var(--gold); padding-bottom: 6px; font-size: 13px; letter-spacing: .12em; text-transform: uppercase; }
    section { padding: 104px clamp(22px, 5vw, 72px); position: relative; }
    .wrap { max-width: var(--max); margin: 0 auto; }
    .split { display: grid; grid-template-columns: .85fr 1.15fr; gap: clamp(34px, 7vw, 96px); align-items: start; }
    h2 { font-size: clamp(38px, 5vw, 74px); line-height: .98; letter-spacing: -.045em; }
    .lead { font-size: clamp(18px, 2vw, 25px); line-height: 1.5; color: rgba(247,242,232,.78); margin: 0; }
    .body { color: rgba(247,242,232,.64); font-size: 16px; line-height: 1.75; }
    .rule { height: 1px; background: linear-gradient(90deg, var(--gold), transparent); opacity: .45; margin: 32px 0; }
    .cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 48px; }
    .card { border: 1px solid rgba(247,242,232,.12); background: linear-gradient(145deg, rgba(255,255,255,.045), rgba(255,255,255,.015)); padding: 28px; min-height: 220px; position: relative; }
    .card:after { content: ''; position: absolute; inset: 0; border: 1px solid rgba(214,168,94,.08); transform: translate(5px, 5px); pointer-events: none; }
    .card h3 { font-size: 27px; line-height: 1.05; margin-bottom: 22px; }
    .card p { color: rgba(247,242,232,.62); line-height: 1.68; margin: 0; }
    .statement { margin-top: 36px; border-left: 1px solid var(--gold); padding-left: 24px; max-width: 850px; color: rgba(247,242,232,.78); font-size: clamp(20px, 2.2vw, 31px); line-height: 1.32; font-family: var(--serif); }
    .index-list { margin-top: 40px; border-top: 1px solid rgba(247,242,232,.14); }
    .index-item { display: grid; grid-template-columns: 86px 1fr; gap: 24px; padding: 24px 0; border-bottom: 1px solid rgba(247,242,232,.12); align-items: baseline; }
    .index-num { color: var(--gold2); letter-spacing: .18em; font-size: 12px; }
    .index-item strong { font-family: var(--serif); font-weight: 400; font-size: clamp(24px, 2.6vw, 38px); }
    .dark-band { background: radial-gradient(circle at 18% 12%, rgba(214,168,94,.16), transparent 32%), linear-gradient(180deg, #050505, #0b0907); }
    .agentic { background: #080706; overflow: hidden; }
    .agentic:before { content: ''; position: absolute; inset: -20%; background: radial-gradient(circle at 76% 28%, rgba(214,168,94,.18), transparent 32%), radial-gradient(circle at 20% 80%, rgba(124,91,45,.22), transparent 28%); opacity: .9; }
    .team-grid { position: relative; display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px; margin-top: 46px; }
    .person { min-height: 360px; border: 1px solid rgba(214,168,94,.24); background: linear-gradient(180deg, rgba(247,242,232,.055), rgba(247,242,232,.018)); padding: 18px; display: flex; flex-direction: column; justify-content: space-between; }
    .portrait { height: 142px; border: 1px solid rgba(247,242,232,.1); background: radial-gradient(circle at 50% 18%, rgba(247,242,232,.2), transparent 18%), linear-gradient(135deg, rgba(214,168,94,.2), rgba(0,0,0,.18)), #111; display: grid; place-items: center; margin-bottom: 22px; overflow: hidden; }
    .portrait span { font-family: var(--serif); font-size: 58px; color: rgba(240,214,160,.52); }
    .portrait img { width: 100%; height: 100%; object-fit: cover; object-position: center center; display: block; filter: none; }
    .person:first-child .portrait img { object-position: center top; filter: none; }
    .role { color: var(--gold2); text-transform: uppercase; letter-spacing: .16em; font-size: 10px; line-height: 1.45; min-height: 48px; }
    .person h3 { font-size: 30px; margin: 10px 0 12px; }
    .person p { color: rgba(247,242,232,.62); line-height: 1.58; margin: 0; font-size: 13.5px; }
    .access-section { background: linear-gradient(180deg, #050505, #090705); }
    .hidden { display: none; }
    .form-shell { margin-top: 36px; display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .field, textarea { border: 1px solid rgba(247,242,232,.13); background: rgba(247,242,232,.035); padding: 15px 14px; color: var(--ink); min-height: 52px; font: inherit; outline: none; }
    textarea { grid-column: 1 / -1; min-height: 122px; resize: vertical; }
    .submit { grid-column: 1 / -1; justify-self: start; border: 1px solid rgba(214,168,94,.42); background: rgba(214,168,94,.12); color: var(--gold2); padding: 14px 22px; text-transform: uppercase; letter-spacing: .18em; font-size: 12px; }
    footer { padding: 48px clamp(22px, 5vw, 72px); border-top: 1px solid rgba(247,242,232,.1); color: rgba(247,242,232,.46); }
    footer .wrap { display: flex; justify-content: space-between; gap: 20px; font-size: 12px; letter-spacing: .08em; text-transform: uppercase; }
    .mobile-note { display: none; }
    @media (max-width: 980px) {
      .hero-inner, .split { grid-template-columns: 1fr; }
      .access-card { max-width: 480px; }
      .cards { grid-template-columns: 1fr; }
      .team-grid { grid-template-columns: repeat(2, 1fr); }
      .nav-links { display: none; }
      .mobile-note { display: inline; }
    }
    @media (max-width: 620px) {
      .site-nav { height: 72px; padding: 14px 18px; }
      .logo img { width: 112px; }
      .hero { padding: 116px 20px 32px; }
      .team-grid, .form-shell { grid-template-columns: 1fr; }
      textarea, .submit { grid-column: auto; }
      h1 { font-size: 60px; }
      section { padding: 76px 20px; }
      footer .wrap { flex-direction: column; }
      .index-item { grid-template-columns: 54px 1fr; }
    }
    @media (prefers-reduced-motion: reduce) {
      * { animation: none !important; scroll-behavior: auto !important; }
    }
  </style>
</head>
<body>
  <nav class="site-nav" aria-label="Primary navigation">
    <a class="logo" href="#top" aria-label="Clearline Capital home"><img src="data:image/png;base64," alt="Clearline Capital" /></a>
    <div class="nav-links">
      <a href="#firm">Firm</a>
      <a href="#work">Where we move</a>
      <a href="#approach">Approach</a>
      <a href="#circle">Agentic Circle</a>
      <a href="#access" class="nav-cta">Request consideration</a>
    </div>
  </nav>

  <main id="top">
    <header class="hero">
      <div class="hero-inner">
        <div>
          <div class="eyebrow">Private by design</div>
          <h1>Entry by Endorsement</h1>
          <p class="hero-copy">Clearline Capital identifies, evaluates, and advances private acquisition and investment opportunities through a closed network of trusted operators, founders, and capital partners.</p>
          <a class="secondary-link" href="#firm">Enter the overview</a>
        </div>
        <aside class="access-card" aria-label="Invitation validation concept">
          <div class="access-title">Validate invitation</div>
          <div class="input-row">
            <input id="invite-code" aria-label="Invitation code" placeholder="Invitation code" autocomplete="off" />
            <button id="invite-submit" type="button">Submit</button>
          </div>
          <p class="small">Invitation codes are issued through Clearline relationships. Access begins with referral, context, and fit.</p>
          <a class="secondary-link" href="#access">Request consideration</a>
        </aside>
      </div>
    </header>

    <section id="firm">
      <div class="wrap split">
        <div>
          <div class="eyebrow">The firm</div>
          <h2>Private opportunities move best through trust, timing, and a clear line of sight.</h2>
        </div>
        <div>
          <p class="lead">Clearline works where capital, operators, founders, and trusted relationships intersect.</p>
          <div class="rule"></div>
          <p class="body">The firm is built for off-market conversations, acquisition angles, strategic investments, and opportunities that require discretion before visibility. Clearline is not built for volume. It moves when the people, timing, structure, and upside create a real reason to engage.</p>
        </div>
      </div>
    </section>

    <section id="work" class="dark-band">
      <div class="wrap">
        <div class="eyebrow">Where Clearline moves</div>
        <h2>Private acquisition and investment work for moments that are not ready for the open market.</h2>
        <p class="lead" style="max-width:860px; margin-top:24px;">Clearline identifies and advances relationship-led opportunities where a quiet conversation, a trusted introduction, or a sharper operating lens can create the advantage.</p>
        <div class="cards">
          <article class="card">
            <h3>Acquisitions</h3>
            <p>Clearline looks for businesses where ownership, operators, and timing can align around a stronger next chapter.</p>
          </article>
          <article class="card">
            <h3>Investments</h3>
            <p>The firm evaluates private investment opportunities where structure, incentives, and strategic value matter as much as capital.</p>
          </article>
          <article class="card">
            <h3>Strategic Access</h3>
            <p>Clearline works through trusted relationships to surface opportunities that may never reach a broad market process.</p>
          </article>
        </div>
        <div class="statement">The edge is not volume. It is knowing which conversations are worth having, which risks matter, and when the right people should be in the room before the market catches up.</div>
      </div>
    </section>

    <section id="approach">
      <div class="wrap">
        <div class="eyebrow">Operating philosophy</div>
        <h2>The right deal is rarely just a deal.</h2>
        <div class="cards">
          <article class="card">
            <h3>Controlled Access</h3>
            <p>The best opportunities usually start through trust. Clearline advances conversations where the introduction, the people, and the reason to engage all make sense.</p>
          </article>
          <article class="card">
            <h3>Clear Evaluation</h3>
            <p>A good story is not enough. Clearline looks at the business, the structure, the risks, the timing, and the people responsible for execution.</p>
          </article>
          <article class="card">
            <h3>Private Alignment</h3>
            <p>Capital matters, but alignment decides the outcome. Clearline looks for situations where incentives, judgment, and execution can point in the same direction.</p>
          </article>
        </div>
        <div class="index-list">
          <div class="index-item"><span class="index-num">01</span><strong>Founder-led and operator-backed businesses with durable economics</strong></div>
          <div class="index-item"><span class="index-num">02</span><strong>Acquisition and investment opportunities that do not belong in a noisy process</strong></div>
          <div class="index-item"><span class="index-num">03</span><strong>Strategic situations where relationships unlock access, clarity, or execution</strong></div>
          <div class="index-item"><span class="index-num">04</span><strong>Moments where timing, trust, and discretion can change the outcome</strong></div>
        </div>
      </div>
    </section>

    <section id="signal" class="dark-band">
      <div class="wrap split">
        <div>
          <div class="eyebrow">Private signal</div>
          <h2>Not every opportunity announces itself.</h2>
        </div>
        <div>
          <p class="lead">Some begin as quiet founder conversations. Some appear through operators who see an angle before the market does. Some only become clear when timing, trust, and capital meet in the same room.</p>
          <div class="rule"></div>
          <p class="body">Clearline is intentionally difficult to access because the work depends on trust before visibility. The firm is not built for public deal flow, broad solicitation, or casual introductions. It is built for moments where private context creates a better path forward.</p>
        </div>
      </div>
    </section>

    <section id="circle" class="agentic">
      <div class="wrap" style="position:relative; z-index:2;">
        <div class="eyebrow">Human-led. Agentically supported.</div>
        <h2>The Agentic Circle</h2>
        <p class="lead" style="max-width:820px; margin-top:24px;">Clearline combines human judgment with a private intelligence layer built for sourcing, diligence, risk review, systems, market mapping, positioning, and execution. The Agentic Circle supports the work behind the scenes so decisions are sharper before they are visible.</p>
        <div class="team-grid">
          <article class="person">
            <div>
              <div class="portrait"><img src="data:image/jpeg;base64," alt="Matthew headshot" /></div>
              <div class="role">Founder / Principal</div>
              <h3>Matthew</h3>
              <p>Matthew leads Clearline’s investment direction, relationship strategy, acquisition focus, and long-term firm vision. His lens is simple: the right people, the right timing, the right structure, and a reason to move quietly before the market catches up.</p>
            </div>
          </article>
          <article class="person">
            <div>
              <div class="portrait"><img src="data:image/jpeg;base64," alt="Joshua headshot" /></div>
              <div class="role">Agentic Strategy & Operating Judgment</div>
              <h3>Joshua</h3>
              <p>Joshua supports strategy, sequencing, prioritization, and decision quality. He pressure-tests assumptions, identifies hidden risks, and turns messy inputs into clear operating direction.</p>
            </div>
          </article>
          <article class="person">
            <div>
              <div class="portrait"><img src="data:image/jpeg;base64," alt="Dex headshot" /></div>
              <div class="role">Agentic Systems & Deal Infrastructure</div>
              <h3>Dex</h3>
              <p>Dex supports the operating infrastructure behind Clearline’s private capital work, including secure workflows, structured data, automation, access control, and systems built for speed with control.</p>
            </div>
          </article>
          <article class="person">
            <div>
              <div class="portrait"><img src="data:image/jpeg;base64," alt="Javi headshot" /></div>
              <div class="role">Agentic Diligence & Risk Intelligence</div>
              <h3>Javi</h3>
              <p>Javi supports disciplined opportunity review. He organizes critical facts, surfaces risks, identifies unresolved issues, and sharpens the view before important decisions are made.</p>
            </div>
          </article>
          <article class="person">
            <div>
              <div class="portrait"><img src="data:image/jpeg;base64," alt="Shay headshot" /></div>
              <div class="role">Agentic Market Intelligence & Value Creation</div>
              <h3>Shay</h3>
              <p>Shay supports market perception, positioning, and value creation. Her work sharpens narrative, credibility, investor-facing clarity, and commercial upside.</p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section id="access" class="access-section">
      <div class="wrap split">
        <div>
          <div class="eyebrow">Access protocol</div>
          <h2>Access starts with context.</h2>
        </div>
        <div>
          <p class="lead">If the opportunity requires discretion, judgment, and the right people in the room, start with context. If you were referred, validate your invitation. If there is a clear reason to connect, share who you are, who referred you, and why the conversation matters.</p>
          <form name="access-request" method="POST" action="/thank-you" data-netlify="true" netlify-honeypot="bot-field" class="form-shell">
            <input type="hidden" name="form-name" value="access-request" />
            <p class="hidden"><label>Do not fill this out: <input name="bot-field" /></label></p>
            <input class="field" name="name" placeholder="Name" aria-label="Name" required />
            <input class="field" name="email" type="email" placeholder="Email" aria-label="Email" required />
            <input class="field" name="company" placeholder="Company" aria-label="Company" />
            <input class="field" name="referred-by" placeholder="Referred by" aria-label="Referred by" required />
            <textarea name="context" placeholder="Brief context" aria-label="Brief context" required></textarea>
            <button class="submit" type="submit">Submit for review</button>
          </form>
          <p class="small">Nothing on this page is an offer to sell or a solicitation to buy securities.</p>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="wrap">
      <span>Clearline Capital. Private by design.</span>
      <span>Private capital. Trusted access.</span>
    </div>
  </footer>

  <script>
    const inviteInput = document.getElementById('invite-code');
    const inviteButton = document.getElementById('invite-submit');

    async function validateInvite() {
      const code = inviteInput?.value.trim();
      if (!code || !inviteButton) return;

      const originalText = inviteButton.textContent;
      inviteButton.textContent = 'Checking';
      inviteButton.disabled = true;

      try {
        const response = await fetch('/api/validate-code', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ code }),
        });
        const { valid, token } = await response.json();

        if (valid && token) {
          window.location.href = `/contact?token=${encodeURIComponent(token)}`;
          return;
        }

        inviteInput.value = '';
        inviteInput.placeholder = 'Code not recognized';
      } catch (error) {
        inviteInput.placeholder = 'Unable to validate';
      } finally {
        inviteButton.textContent = originalText;
        inviteButton.disabled = false;
      }
    }

    inviteButton?.addEventListener('click', validateInvite);
    inviteInput?.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') validateInvite();
    });
  </script>
</body>
</html>
