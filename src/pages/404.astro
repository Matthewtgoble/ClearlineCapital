<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <title>Page Not Found | Clearline Capital</title>
  <meta name="description" content="The requested Clearline Capital page could not be found." />
  <meta name="robots" content="noindex, nofollow" />
  <style>
    :root {
      --black: #050505;
      --ink: #f7f2e8;
      --muted: rgba(247,242,232,.66);
      --line: rgba(218,174,98,.30);
      --gold: #d6a85e;
      --gold2: #f0d6a0;
      --serif: Georgia, 'Times New Roman', serif;
      --sans: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }
    * { box-sizing: border-box; }
    html { min-height: 100%; }
    body {
      min-height: 100svh;
      margin: 0;
      background:
        radial-gradient(circle at 24% 22%, rgba(214,168,94,.10), transparent 32%),
        linear-gradient(180deg, #050505 0%, #080604 54%, #050505 100%);
      color: var(--ink);
      font-family: var(--sans);
      letter-spacing: -.01em;
      overflow-x: hidden;
    }
    body:before {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      opacity: .08;
      background-image: radial-gradient(rgba(255,255,255,.42) .5px, transparent .5px);
      background-size: 3px 3px;
      mix-blend-mode: overlay;
    }
    .page {
      min-height: 100svh;
      display: grid;
      place-items: center;
      padding: clamp(28px, 6vw, 72px);
    }
    .panel {
      width: min(100%, 760px);
      border-top: 1px solid var(--line);
      border-bottom: 1px solid rgba(247,242,232,.10);
      padding: clamp(42px, 7vw, 78px) 0;
      text-align: center;
    }
    .logo {
      display: inline-flex;
      margin-bottom: clamp(30px, 5vw, 46px);
    }
    .logo img {
      width: clamp(112px, 14vw, 142px);
      height: auto;
      display: block;
    }
    .eyebrow {
      margin: 0 0 18px;
      color: var(--gold2);
      font-size: 12px;
      letter-spacing: .30em;
      text-transform: uppercase;
    }
    h1 {
      max-width: 650px;
      margin: 0 auto;
      font-family: var(--serif);
      font-size: clamp(40px, 6vw, 70px);
      font-weight: 400;
      line-height: 1.02;
      letter-spacing: -.045em;
      text-wrap: pretty;
    }
    .body {
      max-width: 420px;
      margin: 24px auto 0;
      color: var(--muted);
      font-size: 15px;
      line-height: 1.7;
    }
    .return-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-top: 34px;
      min-height: 46px;
      border: 1px solid rgba(214,168,94,.46);
      background: rgba(214,168,94,.10);
      color: var(--gold2);
      padding: 0 22px;
      text-decoration: none;
      font-size: 12px;
      letter-spacing: .18em;
      text-transform: uppercase;
    }
    .return-link:hover { border-color: rgba(240,214,160,.78); }
    .return-link:focus-visible {
      outline: 2px solid var(--gold2);
      outline-offset: 5px;
    }
    @media (max-width: 560px) {
      .page { align-items: start; padding-top: 54px; }
      .panel { padding: 34px 0 46px; }
      .eyebrow { font-size: 10px; letter-spacing: .24em; }
      h1 { font-size: clamp(36px, 11vw, 48px); }
      .body { font-size: 14px; }
    }
    @media (prefers-reduced-motion: reduce) {
      * { animation: none !important; transition: none !important; scroll-behavior: auto !important; }
    }
  </style>
</head>
<body>
  <main class="page" aria-labelledby="not-found-title">
    <section class="panel">
      <a href="/" class="logo" aria-label="Clearline Capital home">
        <img src="/logo-champagne-132.webp" srcset="/logo-champagne-132.webp 132w, /logo-champagne-264.webp 264w" sizes="142px" width="132" height="83" alt="Clearline Capital" />
      </a>
      <p class="eyebrow">CLEARLINE CAPITAL</p>
      <h1 id="not-found-title">The requested page could not be found.</h1>
      <p class="body">Return to the firm overview to continue.</p>
      <a class="return-link" href="/">RETURN TO SITE</a>
    </section>
  </main>
</body>
</html>
