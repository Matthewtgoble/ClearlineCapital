<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <title>Submission Terms | Clearline Capital</title>
  <meta name="description" content="Submission Terms for the Clearline Capital public website." />
  <style>

    :root { --black:#050505; --ink:#f7f2e8; --muted:rgba(247,242,232,.68); --soft:rgba(247,242,232,.42); --line:rgba(218,174,98,.28); --gold:#d6a85e; --gold2:#f0d6a0; --serif:Georgia,'Times New Roman',serif; --sans:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; }
    * { box-sizing:border-box; }
    html { scroll-behavior:smooth; }
    body { margin:0; background:linear-gradient(180deg,#050505,#080705 48%,#050505); color:var(--ink); font-family:var(--sans); overflow-x:hidden; }
    body:before { content:''; position:fixed; inset:0; pointer-events:none; z-index:0; opacity:.08; background-image:radial-gradient(rgba(255,255,255,.45) .5px,transparent .5px); background-size:3px 3px; mix-blend-mode:overlay; }
    a { color:inherit; }
    .site-nav { position:sticky; top:0; z-index:5; min-height:86px; display:flex; align-items:center; justify-content:space-between; gap:20px; padding:16px clamp(20px,4vw,54px); background:rgba(5,5,5,.94); border-bottom:1px solid rgba(247,242,232,.09); min-width:0; }
    .logo { flex:0 0 auto; }
    .logo img { width:118px; height:auto; display:block; }
    .back-link { color:var(--gold2); font-size:11px; letter-spacing:.18em; text-transform:uppercase; text-decoration:none; border-bottom:1px solid rgba(214,168,94,.55); padding-bottom:5px; text-align:right; }
    main { position:relative; z-index:1; padding:clamp(64px,8vw,108px) clamp(22px,5vw,72px); }
    .legal-shell { max-width:1220px; margin:0 auto; display:grid; grid-template-columns:minmax(330px,390px) minmax(0,1fr); column-gap:clamp(56px,6vw,96px); row-gap:44px; align-items:start; }
    .legal-shell > aside, .legal-body { min-width:0; }
    .legal-kicker { color:var(--gold2); text-transform:uppercase; letter-spacing:.30em; font-size:12px; margin-bottom:18px; }
    h1,h2 { font-family:var(--serif); font-weight:400; margin:0; text-wrap:pretty; }
    h1 { max-width:390px; font-size:clamp(46px,5.2vw,76px); line-height:.98; letter-spacing:-.045em; overflow-wrap:normal; }
    .meta { margin-top:24px; color:var(--soft); font-size:12px; line-height:1.65; letter-spacing:.06em; text-transform:uppercase; }
    .side-nav { position:sticky; top:118px; border-top:1px solid var(--line); padding-top:18px; display:grid; gap:12px; }
    .side-nav a { color:rgba(247,242,232,.62); text-decoration:none; font-size:11px; letter-spacing:.15em; text-transform:uppercase; line-height:1.45; overflow-wrap:anywhere; }
    .side-nav a:hover { color:var(--gold2); }
    .legal-body { border-top:1px solid rgba(214,168,94,.34); padding-top:8px; }
    .legal-body section { padding:34px 0; border-bottom:1px solid rgba(247,242,232,.09); }
    .legal-body h2 { color:var(--gold2); font-size:clamp(24px,2.7vw,34px); line-height:1.08; letter-spacing:-.02em; margin-bottom:18px; scroll-margin-top:126px; overflow-wrap:anywhere; }
    .legal-body p, .legal-body li { color:rgba(247,242,232,.72); font-size:15px; line-height:1.78; }
    .legal-body p { margin:0 0 14px; }
    .legal-body ul { margin:0 0 14px; padding-left:20px; }
    footer { position:relative; z-index:1; padding:38px clamp(22px,5vw,72px); border-top:1px solid rgba(247,242,232,.1); color:rgba(247,242,232,.62); }
    footer .wrap { max-width:1180px; margin:0 auto; display:grid; gap:18px; }
    .footer-disclaimer { max-width:980px; font-size:12px; line-height:1.65; color:rgba(247,242,232,.58); }
    .footer-links { display:flex; flex-wrap:wrap; gap:12px 20px; }
    .footer-links a { color:var(--gold2); font-size:11px; letter-spacing:.14em; text-transform:uppercase; text-decoration:none; }
    @media (max-width:1180px) { .legal-shell { grid-template-columns:1fr; max-width:760px; row-gap:40px; } .side-nav { position:static; grid-template-columns:1fr 1fr; } h1 { max-width:720px; font-size:clamp(44px,7vw,68px); } }
    @media (max-width:760px) { .site-nav { min-height:72px; } main { padding-top:54px; } h1 { font-size:clamp(38px,11vw,52px); max-width:100%; } .legal-body p, .legal-body li { font-size:14px; line-height:1.7; } }
    @media (max-width:430px) { .site-nav { gap:14px; } .logo img { width:108px; } .back-link { font-size:10px; letter-spacing:.14em; } .side-nav { grid-template-columns:1fr; } }

  </style>
</head>
<body>
  <nav class="site-nav" aria-label="Legal navigation">
    <a class="logo" href="/" aria-label="Clearline Capital home"><img src="/logo-champagne-132.webp" srcset="/logo-champagne-132.webp 132w, /logo-champagne-264.webp 264w" sizes="118px" width="132" height="83" alt="Clearline Capital" /></a>
    <a class="back-link" href="/">Return to site</a>
  </nav>
  <main>
    <div class="legal-shell">
      <aside aria-label="Page sections">
        <div class="legal-kicker">Clearline Capital</div>
        <h1>Submission Terms</h1>
        <div class="meta">Effective date: 2026-07-22<br />Policy version: CLC-SUBMISSION-TERMS-2026-07-22-v1</div>
        <nav class="side-nav">
          <a href="#scope">Scope</a>
          <a href="#do-not-submit-confidential-or-sensitive-information-without-a-separate-agreement">Do not submit confidential or sensitive information without a separate agreement</a>
          <a href="#authorization-to-submit">Authorization to submit</a>
          <a href="#permission-to-review">Permission to review</a>
          <a href="#legal-acceptance">Legal acceptance</a>
          <a href="#no-obligation-to-respond-or-proceed">No obligation to respond or proceed</a>
          <a href="#no-compensation-or-exclusivity-without-a-signed-written-agreement">No compensation or exclusivity without a signed written agreement</a>
          <a href="#no-ownership-transfer-of-submitted-materials">No ownership transfer of submitted materials</a>
        </nav>
      </aside>
      <article class="legal-body">
        <section>
              <h2 id="scope">Scope</h2>
              <p>These Submission Terms apply to Access requests, introductions, referrals, opportunity submissions, company information, and related materials submitted through the Clearline Capital LLC public website.</p>
              </section>
            <section>
              <h2 id="do-not-submit-confidential-or-sensitive-information-without-a-separate-agreement">Do not submit confidential or sensitive information without a separate agreement</h2>
              <p>Please do not submit confidential, proprietary, regulated, or sensitive personal information unless a separate written confidentiality agreement is in place. Submitting information through the public website does not create a confidential relationship or confidentiality obligation.</p>
              </section>
            <section>
              <h2 id="authorization-to-submit">Authorization to submit</h2>
              <p>By submitting information, you represent that you have the right and authority to submit it and that your submission does not violate any law, contract, confidentiality obligation, fiduciary duty, employment duty, privacy right, intellectual-property right, or other third-party right.</p>
              </section>
            <section>
              <h2 id="permission-to-review">Permission to review</h2>
              <p>By submitting information, you authorize Clearline Capital LLC to receive, route, review, retain, and evaluate the submission for its internal business purposes in accordance with the Privacy Policy.</p>
              </section>
            <section>
              <h2 id="legal-acceptance">Legal acceptance</h2>
              <p>Before submitting an Access request, you must affirmatively acknowledge the Privacy Policy and agree to the Terms of Use and Submission Terms. Clearline Capital LLC may maintain records of that acceptance, including the acceptance value, policy-version identifiers, effective dates, and submission timestamp.</p>
              </section>
            <section>
              <h2 id="no-obligation-to-respond-or-proceed">No obligation to respond or proceed</h2>
              <p>A submission does not require Clearline Capital LLC to review, respond, pursue, finance, acquire, partner, or enter into any transaction or relationship.</p>
              </section>
            <section>
              <h2 id="no-compensation-or-exclusivity-without-a-signed-written-agreement">No compensation or exclusivity without a signed written agreement</h2>
              <p>No referral fee, finder fee, brokerage fee, success fee, advisory fee, carried interest, equity right, reimbursement right, or other compensation is created merely by submitting an opportunity, referral, introduction, or related information through the public website.</p>
              <p>Any compensation, fee, reimbursement, equity right, carried interest, exclusivity, or similar arrangement must be set out in a separate written agreement signed by Clearline Capital LLC.</p>
              </section>
            <section>
              <h2 id="no-ownership-transfer-of-submitted-materials">No ownership transfer of submitted materials</h2>
              <p>You retain any rights you have in materials you submit. You grant Clearline Capital LLC permission to use, copy, review, evaluate, route, store, and maintain the submitted materials for internal business review, recordkeeping, compliance, security, and related purposes.</p>
            </section>
      </article>
    </div>
  </main>
  <footer>
    <div class="wrap">
      <p class="footer-disclaimer">Clearline Capital LLC is a private investment and acquisition firm. This website is for informational purposes only. Nothing on this website is an offer to sell, or a solicitation of an offer to buy, securities or interests in any investment vehicle or fund. Submissions do not create a confidential relationship, transaction commitment, exclusivity, compensation right, or obligation for Clearline Capital to respond or proceed. Please review our Legal Disclosures, Privacy Policy, Terms of Use, and Submission Terms.</p>
      <nav class="footer-links" aria-label="Legal links">
          <a href="/legal-disclosures">Legal Disclosures</a>
          <a href="/privacy-policy">Privacy Policy</a>
          <a href="/terms-of-use">Terms of Use</a>
          <a href="/submission-terms">Submission Terms</a>
      </nav>
    </div>
  </footer>
</body>
</html>
