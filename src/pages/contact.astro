---
const year = new Date().getFullYear();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <title>Request Consideration | Clearline Capital</title>
    <meta name="description" content="Request consideration from Clearline Capital through a referred introduction with context, fit, and relevant background." />
    <meta name="robots" content="noindex, nofollow, noarchive" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>

    <div class="fade-overlay" id="fade-overlay"></div>
    <div class="page">

      <main class="contact">
        <div class="contact-inner">
          <div class="contact-heading">
            <p class="eyebrow">Private introduction</p>
            <h1>Begin with context.</h1>
            <p class="contact-sub">Clearline Capital reviews introductions for referral path, fit, and relevance. Please share the information that would make a direct conversation useful.</p>
          </div>

          <form
            name="contact"
            method="POST"
            action="/api/access-submit"
            class="contact-form"
            data-access-form
          >
            <input type="hidden" name="form-name" value="Access" />
            <input type="hidden" name="submission_nonce" value="" data-submission-nonce />
            <input type="hidden" name="source_page_url" value="" data-source-page-url />
            <input type="hidden" name="legal_acceptance_required" value="true" />
            <input type="hidden" name="legal_acceptance_text" value="I acknowledge the Privacy Policy and agree to the Terms of Use and Submission Terms. I understand that submitting this form does not create a confidential relationship, transaction commitment, exclusivity, compensation right, or obligation for Clearline Capital to respond or proceed." />
            <input type="hidden" name="privacy_policy_effective_date" value="2026-07-22" />
            <input type="hidden" name="privacy_policy_version" value="CLC-PRIVACY-POLICY-2026-07-22-v1" />
            <input type="hidden" name="terms_of_use_effective_date" value="2026-07-22" />
            <input type="hidden" name="terms_of_use_version" value="CLC-TERMS-OF-USE-2026-07-22-v1" />
            <input type="hidden" name="submission_terms_effective_date" value="2026-07-22" />
            <input type="hidden" name="submission_terms_version" value="CLC-SUBMISSION-TERMS-2026-07-22-v1" />
            <input type="hidden" name="legal_disclosures_effective_date" value="2026-07-22" />
            <input type="hidden" name="legal_disclosures_version" value="CLC-LEGAL-DISCLOSURES-2026-07-22-v1" />
            <input type="hidden" name="combined_legal_package_version" value="CLC-PUBLIC-WEBSITE-LEGAL-PACKAGE-2026-07-22-v1" />
            <p class="legal-notice">Please do not submit confidential, proprietary, regulated, or sensitive personal information unless a separate written confidentiality agreement is in place. A submission does not create a relationship, commitment, exclusivity, compensation right, or obligation for Clearline Capital LLC to review, respond, pursue, finance, or complete any opportunity.</p>
            <p class="hidden"><label>Do not fill this out: <input name="bot-field" tabindex="-1" autocomplete="off" /></label></p>

            <div class="field">
              <input type="text" id="full-name" name="full-name" required autocomplete="name" placeholder=" " />
              <label for="full-name">Full name</label>
            </div>

            <div class="field">
              <input type="tel" id="phone" name="phone" required autocomplete="tel" placeholder=" " />
              <label for="phone">Phone number</label>
            </div>

            <div class="field">
              <input type="email" id="email" name="email" required autocomplete="email" placeholder=" " />
              <label for="email">Email address</label>
            </div>

            <div class="field">
              <input type="text" id="referred-by" name="referred-by" required placeholder=" " />
              <label for="referred-by">Referred by</label>
            </div>

            <div class="field">
              <input type="url" id="linkedin" name="linkedin" autocomplete="url" placeholder=" " />
              <label for="linkedin">LinkedIn profile <span class="opt">optional</span></label>
            </div>

            <div class="field">
              <input type="text" id="instagram" name="instagram" autocomplete="off" placeholder=" " />
              <label for="instagram">Instagram handle <span class="opt">optional</span></label>
            </div>

            <div class="field">
              <input type="text" id="x-handle" name="x-handle" autocomplete="off" placeholder=" " />
              <label for="x-handle">X handle <span class="opt">optional</span></label>
            </div>

            <div class="field field--textarea" style="padding-top: 1.25rem;">
              <textarea id="why-you" name="why-you" rows="4" required placeholder=" "></textarea>
              <label for="why-you">Context for the introduction</label>
            </div>

            <label class="legal-consent" for="legal-acceptance-contact"><input id="legal-acceptance-contact" name="legal_acceptance_value" type="checkbox" value="true" required /> <span>I acknowledge the <a href="/privacy-policy">Privacy Policy</a> and agree to the <a href="/terms-of-use">Terms of Use</a> and <a href="/submission-terms">Submission Terms</a>. I understand that submitting this form does not create a confidential relationship, transaction commitment, exclusivity, compensation right, or obligation for Clearline Capital to respond or proceed.</span></label>
            <p class="form-error" aria-live="polite"></p>
            <button type="submit" class="submit-btn">Submit for review</button>
          </form>
        </div>
      </main>

      <form name="clearline-access-request" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="hidden" aria-hidden="true">
        <input type="hidden" name="form-name" value="clearline-access-request" />
        <input type="hidden" name="internal_submission_id" />
        <input type="hidden" name="submitted_at_utc" />
        <input type="hidden" name="name" />
        <input type="hidden" name="email" />
        <input type="hidden" name="company" />
        <input type="hidden" name="referred_by" />
        <input type="hidden" name="brief_context" />
        <input type="hidden" name="legal_acceptance_value" />
        <input type="hidden" name="privacy_policy_effective_date" />
        <input type="hidden" name="privacy_policy_version" />
        <input type="hidden" name="terms_of_use_effective_date" />
        <input type="hidden" name="terms_of_use_version" />
        <input type="hidden" name="submission_terms_effective_date" />
        <input type="hidden" name="submission_terms_version" />
        <input type="hidden" name="legal_disclosures_effective_date" />
        <input type="hidden" name="legal_disclosures_version" />
        <input type="hidden" name="combined_legal_package_version" />
        <input type="hidden" name="sanitized_source_page_url" />
        <input type="hidden" name="invitation_status" />
        <p><label>Do not fill this out: <input name="bot-field" /></label></p>
      </form>

      <footer>
        <p>Copyright &copy; 2026 Clearline Capital, LLC</p>
        <p class="footer-disclaimer">Clearline Capital LLC is a private investment and acquisition firm. This website is for informational purposes only. Nothing on this website is an offer to sell, or a solicitation of an offer to buy, securities or interests in any investment vehicle or fund. Submissions do not create a confidential relationship, transaction commitment, exclusivity, compensation right, or obligation for Clearline Capital to respond or proceed. Please review our Legal Disclosures, Privacy Policy, Terms of Use, and Submission Terms.</p>
        <nav class="footer-links" aria-label="Legal links">
          <a href="/legal-disclosures">Legal Disclosures</a>
          <a href="/privacy-policy">Privacy Policy</a>
          <a href="/terms-of-use">Terms of Use</a>
          <a href="/submission-terms">Submission Terms</a>
        </nav>
      </footer>

    </div>

  </body>

  <script type="module" src="/js/clearline-contact.js"></script>
</html>

<style>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --gold:      #c9a96e;
    --gold-dim:  rgba(201, 169, 110, 0.45);
    --dark:      #0c0c0c;
    --serif:     'Cormorant Garamond', Georgia, serif;
    --sans:      'Inter', system-ui, sans-serif;
  }

  html {
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  html, body {
    -webkit-font-smoothing: antialiased;
  }

  /* ── Fade overlay ── */
  .fade-overlay {
    position: fixed;
    inset: 0;
    background: #000;
    opacity: 0;
    pointer-events: none;
    z-index: 999;
    transition: opacity 0.25s ease;
  }

  .fade-overlay.visible {
    opacity: 1;
    pointer-events: all;
  }

  .page {
    min-height: 100vh;
    background: #000;
    display: flex;
    flex-direction: column;
  }

  /* ── Contact ── */
  .contact {
    flex: 1;
    padding-block: 4rem;
    padding-inline: 2rem;
  }

  .contact-inner {
    max-width: 600px;
    margin-inline: auto;
  }

  .contact-heading {
    text-align: center;
    margin-bottom: 4.5rem;
  }

  .eyebrow {
    font-family: var(--sans);
    font-size: 0.875rem;
    font-weight: 400;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.1rem;
  }

  h1 {
    font-family: var(--serif);
    font-size: clamp(1.9rem, 4vw, 2.9rem);
    font-weight: 300;
    color: #d4d0cb;
    margin-bottom: 1rem;
  }

  .contact-sub {
    font-size: 0.875rem;
    color: #9e9a95;
    line-height: 1.8;
  }

  .legal-notice {
    color: #9e9a95;
    font-size: 0.78rem;
    line-height: 1.75;
    border-left: 1px solid rgba(201, 169, 110, 0.55);
    padding-left: 1rem;
  }

  /* ── Form ── */
  .hidden { display: none; }

  .contact-form {
    display: grid;
    gap: 3rem;
  }

  .field {
    position: relative;
  }

  .field::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0%;
    height: 1px;
    background: var(--gold);
    transition: width 0.38s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }

  .field:focus-within::after {
    width: 100%;
  }

  .field input {
    display: block;
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(255,255,255,0.15);
    outline: none;
    font-family: var(--sans);
    font-size: 0.95rem;
    font-weight: 300;
    color: #d4d0cb;
    padding-block: 0.5rem 0.65rem;
    transition: border-color 0.3s ease;
    -webkit-text-fill-color: #d4d0cb;
  }

  .field:focus-within input {
    border-bottom-color: transparent;
  }

  .field input:-webkit-autofill,
  .field input:-webkit-autofill:hover,
  .field input:-webkit-autofill:focus,
  .field input:-webkit-autofill:active {
    -webkit-box-shadow: 0 0 0 1000px #000 inset !important;
    -webkit-text-fill-color: #d4d0cb !important;
    caret-color: #d4d0cb;
    transition: background-color 9999s ease-in-out 0s;
  }

  .field label {
    position: absolute;
    top: 0.5rem;
    left: 0;
    font-family: var(--sans);
    font-size: 0.82rem;
    font-weight: 400;
    letter-spacing: 0.03em;
    color: #9e9a95;
    pointer-events: none;
    transform-origin: left top;
    transition:
      transform 0.26s cubic-bezier(0.4, 0, 0.2, 1),
      color 0.26s ease;
  }

  .field input:focus ~ label,
  .field input:not(:placeholder-shown) ~ label {
    transform: translateY(-1.5rem) scale(0.75);
    color: var(--gold);
    letter-spacing: 0.08em;
  }

  .field--textarea textarea {
    display: block;
    width: 100%;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.15);
    outline: none;
    font-family: var(--sans);
    font-size: 0.95rem;
    font-weight: 300;
    color: #d4d0cb;
    padding: 0.75rem 1rem;
    resize: none;
    transition: border-color 0.3s ease;
    -webkit-text-fill-color: #d4d0cb;
  }

  .field--textarea:focus-within textarea {
    border-color: var(--gold);
  }

  .field--textarea::after {
    display: none;
  }

  .field--textarea label {
    top: -1.5rem;
    transform: translateY(0) scale(0.75);
    color: var(--gold);
    letter-spacing: 0.08em;
  }

  .field--textarea textarea:focus ~ label,
  .field--textarea textarea:not(:placeholder-shown) ~ label {
    transform: translateY(0) scale(0.75);
    color: var(--gold);
    letter-spacing: 0.08em;
  }

  .opt {
    font-size: 0.7em;
    font-style: italic;
    color: #9e9a95;
    font-weight: 300;
  }

  .legal-consent {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.75rem;
    align-items: start;
    color: #aaa49d;
    font-size: 0.78rem;
    line-height: 1.65;
  }

  .legal-consent input {
    width: 18px;
    height: 18px;
    margin-top: 0.1rem;
    accent-color: var(--gold);
  }

  .legal-consent input:focus-visible {
    outline: 2px solid #e8c96a;
    outline-offset: 3px;
  }

  .legal-consent a {
    color: var(--gold);
    text-underline-offset: 3px;
  }

  .form-error {
    min-height: 1rem;
    color: var(--gold);
    font-size: 0.76rem;
    line-height: 1.45;
  }

  .submit-btn {
    margin-top: 0.5rem;
    width: 100%;
    background: transparent;
    border: 1px solid var(--gold);
    color: var(--gold);
    font-family: var(--sans);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    padding-block: 1.1rem;
    cursor: pointer;
    transition: background 0.24s ease, color 0.24s ease, border-color 0.24s ease;
  }

  .submit-btn:hover,
  .submit-btn:active {
    background: var(--dark);
    border-color: var(--dark);
    color: var(--gold);
  }

  /* ── Footer ── */
  footer {
    text-align: center;
    padding-block: 2rem;
    flex-shrink: 0;
  }

  footer p {
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    color: var(--gold);
  }

  .footer-disclaimer {
    max-width: 920px;
    margin: 1.4rem auto 0;
    color: rgba(247, 242, 232, 0.58);
    font-size: 0.72rem;
    line-height: 1.8;
    letter-spacing: 0.04em;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem 1.2rem;
    margin-top: 1rem;
  }

  .footer-links a {
    color: var(--gold);
    font-family: var(--sans);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .footer-links a:focus-visible {
    outline: 2px solid var(--gold);
    outline-offset: 4px;
  }

  /* ── Mobile ── */
  @media (max-width: 580px) {
    .contact {
      padding-block: 1rem;
      padding-inline: 1.25rem;
    }

    .contact-heading {
      margin-bottom: 1.75rem;
    }

    h1 {
      font-size: 1.5rem;
    }

    .contact-sub {
      font-size: 0.8rem;
    }

    .contact-form {
      gap: 1.75rem;
    }

    .field input {
      font-size: 16px;
    }

    .legal-consent {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.75rem;
    align-items: start;
    color: #aaa49d;
    font-size: 0.78rem;
    line-height: 1.65;
  }

  .legal-consent input {
    width: 18px;
    height: 18px;
    margin-top: 0.1rem;
    accent-color: var(--gold);
  }

  .legal-consent input:focus-visible {
    outline: 2px solid #e8c96a;
    outline-offset: 3px;
  }

  .legal-consent a {
    color: var(--gold);
    text-underline-offset: 3px;
  }

  .form-error {
    min-height: 1rem;
    color: var(--gold);
    font-size: 0.76rem;
    line-height: 1.45;
  }

  .submit-btn {
      padding-block: 0.85rem;
    }

    footer {
      padding-block: 0.75rem;
      padding-bottom: 10px;
    }
  }
</style>
